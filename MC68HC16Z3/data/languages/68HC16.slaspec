:EORA EOFFY     is op8=0x27; op8b=0x54; EOFFY   { A = A ^ (*:1 EOFFY);  setNZ8(A); V_flag = 0; }
:EORA EOFFZ     is op8=0x27; op8b=0x64; EOFFZ   { A = A ^ (*:1 EOFFZ);  setNZ8(A); V_flag = 0; }

# = STAA: (A) => M =
:STAA IND8X     is op8=0x4A; IND8X     { *:1 IND8X = A; setNZ8(A); V_flag = 0; }
:STAA IND8Y     is op8=0x5A; IND8Y     { *:1 IND8Y = A; setNZ8(A); V_flag = 0; }
:STAA IND8Z     is op8=0x6A; IND8Z     { *:1 IND8Z = A; setNZ8(A); V_flag = 0; }
:STAA IND16X    is op8=0x17; op8b=0x4A; IND16X  { *:1 IND16X = A; setNZ8(A); V_flag = 0; }
:STAA IND16Y    is op8=0x17; op8b=0x5A; IND16Y  { *:1 IND16Y = A; setNZ8(A); V_flag = 0; }
:STAA IND16Z    is op8=0x17; op8b=0x6A; IND16Z  { *:1 IND16Z = A; setNZ8(A); V_flag = 0; }
:STAA EXT16     is op8=0x17; op8b=0x7A; EXT16   { *:1 EXT16 = A;  setNZ8(A); V_flag = 0; }
