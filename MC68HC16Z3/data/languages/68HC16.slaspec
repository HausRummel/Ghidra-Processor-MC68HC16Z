    *:2 ea = val;
    setNZ16(val); V_flag = 0;
}

# BSETW EXT: 27 39 hh ll mmmm
:BSETW addr16^",#"^imm16_2  is op8=0x27; op8b=0x39; addr16; imm16_2 {
    local ea:3 = (zext(EK:1) << 16) | zext(addr16:2);
    local val:2 = *:2 ea;
    val = val | imm16_2;
    *:2 ea = val;
    setNZ16(val); V_flag = 0;
}


# ============================================================================
# SECTION: BRCLR - Branch if Bit(s) Clear
# If (M) & (Mask) = 0, then branch
# Flags: unchanged
# IND8 modes: opcode mm ff rr (mask, 8-bit offset, 8-bit relative)
# IND16/EXT modes: opcode mm gggg/hhll rrrr (mask, 16-bit addr, 16-bit relative)
# ============================================================================

# BRCLR IND8,X: CB mm ff rr
:BRCLR imm8_2^",X,#"^mask8, BRREL8  is op8=0xCB; mask8; imm8_2; BRREL8 {
    local off:1 = imm8_2;
    local ea:3 = (zext(XK:1) << 16) | zext(IX + zext(off));
    local val:1 = *:1 ea;
    local m:1 = mask8;
    if ((val & m) == 0) goto BRREL8;
}

# BRCLR IND8,Y: DB mm ff rr
:BRCLR imm8_2^",Y,#"^mask8, BRREL8  is op8=0xDB; mask8; imm8_2; BRREL8 {
    local off:1 = imm8_2;
    local ea:3 = (zext(YK:1) << 16) | zext(IY + zext(off));
    local val:1 = *:1 ea;
    local m:1 = mask8;
    if ((val & m) == 0) goto BRREL8;
}

# BRCLR IND8,Z: EB mm ff rr
:BRCLR imm8_2^",Z,#"^mask8, BRREL8  is op8=0xEB; mask8; imm8_2; BRREL8 & ctxZK{
    local bank:1 = ctxZK;
    local off:1 = imm8_2;
    local ea:3 = (zext(bank) << 16) | zext(IZ + zext(off));
    local val:1 = *:1 ea;
    local m:1 = mask8;
    if ((val & m) == 0) goto BRREL8;
}

# BRCLR IND16,X: 0A mm gggg rrrr
:BRCLR simm16^",X,#"^mask8, BRREL16  is op8=0x0A; mask8; simm16; BRREL16 {
    local off:2 = simm16;
    local ea:3 = (zext(XK:1) << 16) | zext(IX + off);
    local val:1 = *:1 ea;
    local m:1 = mask8;
    if ((val & m) == 0) goto BRREL16;
}

# BRCLR IND16,Y: 1A mm gggg rrrr
:BRCLR simm16^",Y,#"^mask8, BRREL16  is op8=0x1A; mask8; simm16; BRREL16 {
    local off:2 = simm16;
    local ea:3 = (zext(YK:1) << 16) | zext(IY + off);
    local val:1 = *:1 ea;
    local m:1 = mask8;
    if ((val & m) == 0) goto BRREL16;
}

# BRCLR IND16,Z: 2A mm gggg rrrr
:BRCLR simm16^",Z,#"^mask8, BRREL16  is op8=0x2A; mask8; simm16; BRREL16 & ctxZK{
    local bank:1 = ctxZK;
    local off:2 = simm16;
    local ea:3 = (zext(bank) << 16) | zext(IZ + off);
    local val:1 = *:1 ea;
    local m:1 = mask8;
    if ((val & m) == 0) goto BRREL16;
}

# BRCLR EXT: 3A mm hh ll rrrr
:BRCLR addr16^",#"^mask8, BRREL16  is op8=0x3A; mask8; addr16; BRREL16 {
    local a:2 = addr16;
    local ea:3 = (zext(EK:1) << 16) | zext(a);
    local val:1 = *:1 ea;
    local m:1 = mask8;
    if ((val & m) == 0) goto BRREL16;
}


# ============================================================================
# SECTION: BRSET - Branch if Bit(s) Set
# If (M) & (Mask) = Mask, then branch (i.e., all masked bits are set)
# Flags: unchanged
# ============================================================================

# BRSET IND8,X: 8B mm ff rr
:BRSET imm8_2^",X,#"^mask8, BRREL8  is op8=0x8B; mask8; imm8_2; BRREL8 {
    local off:1 = imm8_2;
    local ea:3 = (zext(XK:1) << 16) | zext(IX + zext(off));
    local val:1 = *:1 ea;
    local m:1 = mask8;
    if ((val & m) == m) goto BRREL8;
}

# BRSET IND8,Y: 9B mm ff rr
:BRSET imm8_2^",Y,#"^mask8, BRREL8  is op8=0x9B; mask8; imm8_2; BRREL8 {
    local off:1 = imm8_2;
    local ea:3 = (zext(YK:1) << 16) | zext(IY + zext(off));
    local val:1 = *:1 ea;
    local m:1 = mask8;
    if ((val & m) == m) goto BRREL8;
}

# BRSET IND8,Z: AB mm ff rr
:BRSET imm8_2^",Z,#"^mask8, BRREL8  is op8=0xAB; mask8; imm8_2; BRREL8 & ctxZK{
    local bank:1 = ctxZK;
    local off:1 = imm8_2;
    local ea:3 = (zext(bank) << 16) | zext(IZ + zext(off));
    local val:1 = *:1 ea;
    local m:1 = mask8;
    if ((val & m) == m) goto BRREL8;
}

# BRSET IND16,X: 0B mm gggg rrrr
:BRSET simm16^",X,#"^mask8, BRREL16  is op8=0x0B; mask8; simm16; BRREL16 {
    local off:2 = simm16;
    local ea:3 = (zext(XK:1) << 16) | zext(IX + off);
    local val:1 = *:1 ea;
    local m:1 = mask8;
    if ((val & m) == m) goto BRREL16;
}

# BRSET IND16,Y: 1B mm gggg rrrr
:BRSET simm16^",Y,#"^mask8, BRREL16  is op8=0x1B; mask8; simm16; BRREL16 {
    local off:2 = simm16;
    local ea:3 = (zext(YK:1) << 16) | zext(IY + off);
    local val:1 = *:1 ea;
    local m:1 = mask8;
    if ((val & m) == m) goto BRREL16;
}

# BRSET IND16,Z: 2B mm gggg rrrr
:BRSET simm16^",Z,#"^mask8, BRREL16  is op8=0x2B; mask8; simm16; BRREL16 & ctxZK{
    local bank:1 = ctxZK;
    local off:2 = simm16;
    local ea:3 = (zext(bank) << 16) | zext(IZ + off);
    local val:1 = *:1 ea;
    local m:1 = mask8;
    if ((val & m) == m) goto BRREL16;
}

# BRSET EXT: 3B mm hh ll rrrr
:BRSET addr16^",#"^mask8, BRREL16  is op8=0x3B; mask8; addr16; BRREL16 {
    local a:2 = addr16;
    local ea:3 = (zext(EK:1) << 16) | zext(a);
    local val:1 = *:1 ea;
    local m:1 = mask8;
    if ((val & m) == m) goto BRREL16;
}


# ============================================================================
# SECTION: SBCE - Subtract with Carry from E
# (E) - (M:M+1) - C => E
# Flags: N=delta Z=delta V=delta C=delta
# ============================================================================

:SBCE "#"^imm16   is op8=0x37; op8b=0x32; imm16 {
    local c:2 = zext(C_flag);
    subFlags16(E, imm16 + c);
    E = E - imm16 - c;
    setNZ16(E);
}

:SBCE IND16X      is op8=0x37; op8b=0x42; IND16X {
    local val:2 = *:2 IND16X; local c:2 = zext(C_flag);
    subFlags16(E, val + c);
    E = E - val - c;
    setNZ16(E);
}

:SBCE IND16Y      is op8=0x37; op8b=0x52; IND16Y {
    local val:2 = *:2 IND16Y; local c:2 = zext(C_flag);
    subFlags16(E, val + c);
    E = E - val - c;
    setNZ16(E);
}

:SBCE IND16Z      is op8=0x37; op8b=0x62; IND16Z {
    local val:2 = *:2 IND16Z; local c:2 = zext(C_flag);
    subFlags16(E, val + c);
    E = E - val - c;
    setNZ16(E);
}

:SBCE EXT16        is op8=0x37; op8b=0x72; EXT16 {
    local val:2 = *:2 EXT16; local c:2 = zext(C_flag);
    subFlags16(E, val + c);
    E = E - val - c;
    setNZ16(E);
}


# ============================================================================
# SECTION: ADCE - Add with Carry to E
# (E) + (M:M+1) + C => E
# Flags: N=delta Z=delta V=delta C=delta
# ============================================================================

:ADCE "#"^imm16   is op8=0x37; op8b=0x33; imm16 {
    local c:2 = zext(C_flag);
    addFlags16(E, imm16 + c);
    E = E + imm16 + c;
    setNZ16(E);
}

:ADCE IND16X      is op8=0x37; op8b=0x43; IND16X {
    local val:2 = *:2 IND16X; local c:2 = zext(C_flag);
    addFlags16(E, val + c);
    E = E + val + c;
    setNZ16(E);
}

:ADCE IND16Y      is op8=0x37; op8b=0x53; IND16Y {
    local val:2 = *:2 IND16Y; local c:2 = zext(C_flag);
    addFlags16(E, val + c);
    E = E + val + c;
    setNZ16(E);
}

:ADCE IND16Z      is op8=0x37; op8b=0x63; IND16Z {
    local val:2 = *:2 IND16Z; local c:2 = zext(C_flag);
    addFlags16(E, val + c);
    E = E + val + c;
    setNZ16(E);
}

:ADCE EXT16        is op8=0x37; op8b=0x73; EXT16 {
    local val:2 = *:2 EXT16; local c:2 = zext(C_flag);
    addFlags16(E, val + c);
    E = E + val + c;
    setNZ16(E);
}


# ============================================================================
# SECTION: MAC - Multiply and Accumulate (Signed 16-bit Fractions)
# (HR)*(IR) => E:D, (AM)+(E:D) => AM
# Qualified IX/IY update, load HR/IR from memory
# Opcode: 7B xoyo
# The xo:yo byte encodes 4-bit signed offsets for IX and IY modification
# Flags: MV=delta EV=delta V=delta
# ============================================================================

:MAC macoffs  is op8=0x7B; macoffs & mac_xo & mac_yo {
    # Fractional multiply: HR * IR => 32-bit product, shifted left 1
    local prod:4 = sext(HR:2) * sext(IR:2);
    prod = prod << 1;
    E = prod[16,16];
    D = prod[0,16];

    # Accumulate: AM + E:D => AM
    local ed:4 = (zext(E:2) << 16) | zext(D:2);
    AM = AM + ed;

    # Save HR to IZ before loading new values
    IZ = HR;

    # Qualified index register updates using XMSK/YMSK
    local newix:2 = (IX + sext(mac_xo:2)) & zext(XMSK:1);
    newix = newix | (IX & ~zext(XMSK:1));
    IX = newix;

    local newiy:2 = (IY + sext(mac_yo:2)) & zext(YMSK:1);
    newiy = newiy | (IY & ~zext(YMSK:1));
    IY = newiy;

    # Load new HR from (XK:IX), IR from (YK:IY)
    local xaddr:3 = (zext(XK:1) << 16) | zext(IX:2);
    HR = *:2 xaddr;
    local yaddr:3 = (zext(YK:1) << 16) | zext(IY:2);
    IR = *:2 yaddr;
}


# ============================================================================
# SECTION: RMAC - Repeating MAC (Signed 16-bit Fractions)
# Repeat until (E) < 0:
#   (AM)+(H)*(I) => AM, qualified IX/IY, load H/I, E-1 => E
# Opcode: FB xoyo
# ============================================================================

:RMAC macoffs  is op8=0xFB; macoffs & mac_xo & mac_yo {
    # RMAC loops internally until E becomes negative
    # We model a single-pass semantic with a loop pcodeop hint
    local count:2 = E;
    <rmac_loop>
    if (count s< 0) goto <rmac_done>;

    local prod:4 = sext(HR:2) * sext(IR:2);
    prod = prod << 1;
    AM = AM + prod;

    local newix:2 = (IX + sext(mac_xo:2)) & zext(XMSK:1);
    newix = newix | (IX & ~zext(XMSK:1));
    IX = newix;

    local newiy:2 = (IY + sext(mac_yo:2)) & zext(YMSK:1);
    newiy = newiy | (IY & ~zext(YMSK:1));
    IY = newiy;

    local xaddr:3 = (zext(XK:1) << 16) | zext(IX:2);
    HR = *:2 xaddr;
    local yaddr:3 = (zext(YK:1) << 16) | zext(IY:2);
    IR = *:2 yaddr;

    count = count - 1;
    goto <rmac_loop>;
    <rmac_done>
    E = count;
}


# ============================================================================
# SECTION: MAC Register Transfers
# ============================================================================

# TDMSK: Transfer D to XMSK:YMSK  (INH, opcode 372F)
:TDMSK  is op8=0x37; op8b=0x2F  {
    XMSK = A;
    YMSK = B;
}

# TEDM: Transfer E and D to AM[31:0], sign-extend AM  (INH, opcode 27B1)
:TEDM   is op8=0x27; op8b=0xB1  {
    AM = (zext(E:2) << 16) | zext(D:2);
    # Sign-extend: AM[35:32] = sign of AM[31]
    local sign:1 = E[15,1];
    AM_EXT = (sign * 0x0F);
    MV_flag = 0;
    EV_flag = 0;
}

# TEM: Transfer E to AM[31:16], clear AM[15:0], sign-extend  (INH, opcode 27B2)
:TEM    is op8=0x27; op8b=0xB2  {
    AM = zext(E:2) << 16;
    local sign:1 = E[15,1];
    AM_EXT = (sign * 0x0F);
    MV_flag = 0;
    EV_flag = 0;
}

# TMXED: Transfer AM to IX:E:D  (INH, opcode 27B3)
# AM[35:32] => IX[3:0], AM35 sign-ext => IX[15:4]
# AM[31:16] => E, AM[15:0] => D
:TMXED  is op8=0x27; op8b=0xB3  {
    D = AM:2;
    E = AM[16,16];
    local ext:1 = AM_EXT;
    local sign:2 = zext(ext[3,1]);
    sign = sign * 0xFFF0;
    IX = sign | zext(ext & 0x0F);
}

# TMER: Transfer Rounded AM to E  (INH, opcode 27B4)
# Rounds AM[31:16] by adding AM[15], with saturation support
# Flags: MV=delta EV=delta N=delta Z=delta
:TMER   is op8=0x27; op8b=0xB4  {
    local upper:2 = AM[16,16];
    local roundbit:2 = zext(AM[15,1]);
    local result:2 = upper + roundbit;
    # Saturation: if SM=1 and (EV|MV), clamp to max positive or negative
    local saturate:1 = SM_flag & (EV_flag | MV_flag);
    if (saturate == 0) goto <tmer_nosaturate>;
    local signbit:1 = AM_EXT[3,1];
    if (signbit != 0) goto <tmer_negsat>;
    E = 0x7FFF;
    goto <tmer_done>;
    <tmer_negsat>
    E = 0x8000;
    goto <tmer_done>;
    <tmer_nosaturate>
    E = result;
    <tmer_done>
    setNZ16(E);
    # MV and EV updated: check if rounding caused overflow
    local ov:1 = (upper[15,1] != result[15,1]) & (roundbit != 0);
    EV_flag = EV_flag | ov;
}

# TMET: Transfer Truncated AM to E  (INH, opcode 27B5)
# AM[31:16] => E (no rounding), with saturation support
# Flags: N=delta Z=delta
:TMET   is op8=0x27; op8b=0xB5  {
    local saturate:1 = SM_flag & (EV_flag | MV_flag);
    if (saturate == 0) goto <tmet_nosaturate>;
    local signbit:1 = AM_EXT[3,1];
    if (signbit != 0) goto <tmet_negsat>;
    E = 0x7FFF;
    goto <tmet_done>;
    <tmet_negsat>
    E = 0x8000;
    goto <tmet_done>;
    <tmet_nosaturate>
    E = AM[16,16];
    <tmet_done>
    setNZ16(E);
}


# ============================================================================
# SECTION: PSHMAC / PULMAC
# ============================================================================

# PSHMAC: Push all MAC registers onto stack  (INH, opcode 27B8)
# Pushes: AM_EXT, AM(4 bytes), HR, IR, XMSK:YMSK
:PSHMAC  is op8=0x27; op8b=0xB8 {
    # Push XMSK:YMSK as a word
    local masks:2 = (zext(XMSK:1) << 8) | zext(YMSK:1);
    push16(masks);
    push16(IR);
    push16(HR);
    # Push AM as two words (high then low)
    local am_lo:2 = AM:2;
    local am_hi:2 = AM[16,16];
    push16(am_lo);
    push16(am_hi);
    # Push AM extension
    local ext_w:2 = zext(AM_EXT:1);
    push16(ext_w);
}

# PULMAC: Pull all MAC registers from stack  (INH, opcode 27B9)
:PULMAC  is op8=0x27; op8b=0xB9 {
    local ext_w:2 = 0;
    pull16(ext_w);
    AM_EXT = ext_w:1;
    local am_hi:2 = 0;
    pull16(am_hi);
    local am_lo:2 = 0;
    pull16(am_lo);
    AM = (zext(am_hi:2) << 16) | zext(am_lo:2);
    pull16(HR);
    pull16(IR);
    local masks:2 = 0;
    pull16(masks);
    XMSK = masks[8,8];
    YMSK = masks[0,8];
}


# ============================================================================
# END OF SPECIFICATION
