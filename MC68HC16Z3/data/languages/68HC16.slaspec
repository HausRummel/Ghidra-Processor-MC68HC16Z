# = SUBB =
:SUBB IND8X     is op8=0xC0; IND8X     { local val:1 = *:1 IND8X; subFlags(B, val); B = B - val; setNZ8(B); }
:SUBB IND8Y     is op8=0xD0; IND8Y     { local val:1 = *:1 IND8Y; subFlags(B, val); B = B - val; setNZ8(B); }
:SUBB IND8Z     is op8=0xE0; IND8Z     { local val:1 = *:1 IND8Z; subFlags(B, val); B = B - val; setNZ8(B); }
:SUBB "#"^imm8  is op8=0xF0; imm8      { subFlags(B, imm8); B = B - imm8; setNZ8(B); }
:SUBB IND16X    is op8=0x17; op8b=0xC0; IND16X  { local val:1 = *:1 IND16X; subFlags(B, val); B = B - val; setNZ8(B); }
:SUBB IND16Y    is op8=0x17; op8b=0xD0; IND16Y  { local val:1 = *:1 IND16Y; subFlags(B, val); B = B - val; setNZ8(B); }
:SUBB IND16Z    is op8=0x17; op8b=0xE0; IND16Z  { local val:1 = *:1 IND16Z; subFlags(B, val); B = B - val; setNZ8(B); }
:SUBB EXT16     is op8=0x17; op8b=0xF0; EXT16   { local val:1 = *:1 EXT16;  subFlags(B, val); B = B - val; setNZ8(B); }
:SUBB EOFFX     is op8=0x27; op8b=0xC0; EOFFX   { local val:1 = *:1 EOFFX;  subFlags(B, val); B = B - val; setNZ8(B); }
:SUBB EOFFY     is op8=0x27; op8b=0xD0; EOFFY   { local val:1 = *:1 EOFFY;  subFlags(B, val); B = B - val; setNZ8(B); }
:SUBB EOFFZ     is op8=0x27; op8b=0xE0; EOFFZ   { local val:1 = *:1 EOFFZ;  subFlags(B, val); B = B - val; setNZ8(B); }

# = ADDB =
:ADDB IND8X     is op8=0xC1; IND8X     { local val:1 = *:1 IND8X; addFlags(B, val); B = B + val; setNZ8(B); }
:ADDB IND8Y     is op8=0xD1; IND8Y     { local val:1 = *:1 IND8Y; addFlags(B, val); B = B + val; setNZ8(B); }
:ADDB IND8Z     is op8=0xE1; IND8Z     { local val:1 = *:1 IND8Z; addFlags(B, val); B = B + val; setNZ8(B); }
:ADDB "#"^imm8  is op8=0xF1; imm8      { addFlags(B, imm8); B = B + imm8; setNZ8(B); }
:ADDB IND16X    is op8=0x17; op8b=0xC1; IND16X  { local val:1 = *:1 IND16X; addFlags(B, val); B = B + val; setNZ8(B); }
:ADDB IND16Y    is op8=0x17; op8b=0xD1; IND16Y  { local val:1 = *:1 IND16Y; addFlags(B, val); B = B + val; setNZ8(B); }
:ADDB IND16Z    is op8=0x17; op8b=0xE1; IND16Z  { local val:1 = *:1 IND16Z; addFlags(B, val); B = B + val; setNZ8(B); }
:ADDB EXT16     is op8=0x17; op8b=0xF1; EXT16   { local val:1 = *:1 EXT16;  addFlags(B, val); B = B + val; setNZ8(B); }
:ADDB EOFFX     is op8=0x27; op8b=0xC1; EOFFX   { local val:1 = *:1 EOFFX;  addFlags(B, val); B = B + val; setNZ8(B); }
:ADDB EOFFY     is op8=0x27; op8b=0xD1; EOFFY   { local val:1 = *:1 EOFFY;  addFlags(B, val); B = B + val; setNZ8(B); }
:ADDB EOFFZ     is op8=0x27; op8b=0xE1; EOFFZ   { local val:1 = *:1 EOFFZ;  addFlags(B, val); B = B + val; setNZ8(B); }

# = SBCB =
:SBCB IND8X     is op8=0xC2; IND8X     { local val:1 = *:1 IND8X; local c:1 = C_flag; subFlags(B, val+c); B = B - val - c; setNZ8(B); }
:SBCB IND8Y     is op8=0xD2; IND8Y     { local val:1 = *:1 IND8Y; local c:1 = C_flag; subFlags(B, val+c); B = B - val - c; setNZ8(B); }
:SBCB IND8Z     is op8=0xE2; IND8Z     { local val:1 = *:1 IND8Z; local c:1 = C_flag; subFlags(B, val+c); B = B - val - c; setNZ8(B); }
:SBCB "#"^imm8  is op8=0xF2; imm8      { local c:1 = C_flag; subFlags(B, imm8+c); B = B - imm8 - c; setNZ8(B); }
:SBCB IND16X    is op8=0x17; op8b=0xC2; IND16X  { local val:1 = *:1 IND16X; local c:1 = C_flag; subFlags(B, val+c); B = B - val - c; setNZ8(B); }
:SBCB IND16Y    is op8=0x17; op8b=0xD2; IND16Y  { local val:1 = *:1 IND16Y; local c:1 = C_flag; subFlags(B, val+c); B = B - val - c; setNZ8(B); }
:SBCB IND16Z    is op8=0x17; op8b=0xE2; IND16Z  { local val:1 = *:1 IND16Z; local c:1 = C_flag; subFlags(B, val+c); B = B - val - c; setNZ8(B); }
:SBCB EXT16     is op8=0x17; op8b=0xF2; EXT16   { local val:1 = *:1 EXT16;  local c:1 = C_flag; subFlags(B, val+c); B = B - val - c; setNZ8(B); }

# = ADCB =
:ADCB IND8X     is op8=0xC3; IND8X     { local val:1 = *:1 IND8X; local c:1 = C_flag; addFlags(B, val+c); B = B + val + c; setNZ8(B); }
:ADCB IND8Y     is op8=0xD3; IND8Y     { local val:1 = *:1 IND8Y; local c:1 = C_flag; addFlags(B, val+c); B = B + val + c; setNZ8(B); }
:ADCB IND8Z     is op8=0xE3; IND8Z     { local val:1 = *:1 IND8Z; local c:1 = C_flag; addFlags(B, val+c); B = B + val + c; setNZ8(B); }
