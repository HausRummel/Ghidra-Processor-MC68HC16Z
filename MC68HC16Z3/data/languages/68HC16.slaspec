}


# ============================================================================
# SECTION: BSET - Set Bit(s) in memory byte
# (M) | (Mask) => M
# Flags: N=delta Z=delta V=0 C=--
# ============================================================================

# BSET IND8,X: 17 09 mm ff
:BSET imm8_2^",X,#"^mask8  is op8=0x17; op8b=0x09; mask8; imm8_2 {
    local off:1 = imm8_2;
