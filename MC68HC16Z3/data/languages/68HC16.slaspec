# =============================================================================
# MC68HC16 (CPU16) Processor Module for Ghidra
# =============================================================================
# Based on the CPU16 Reference Manual (CPU16RM/AD) and MC68HC16Z User's Manual
#
# Architecture overview:
#   - Big-endian, 16-bit data bus
#   - 20-bit linear address space (1 MB), represented in 24-bit (3-byte) addresses
#   - Variable-length instructions (2-8 bytes)
#   - Opcode pages: page1 (no prefix), page2 (prefix 0x17), page3 (prefix 0x27), page4 (prefix 0x37)
#   - Registers: A(8), B(8), D=A:B(16), E(16), IX(16), IY(16), IZ(16), SP(16), PC(16)
#   - Extension fields: PK, SK, EK, XK, YK, ZK (4-bit each)
#   - CCR(16): S,MV,H,EV,N,Z,V,C,IP[2:0],SM,PK[3:0]
#   - MAC registers: HR(16), IR(16), AM(36-bit), XMSK(8), YMSK(8)
# =============================================================================

define endian=big;
define alignment=2;

# =============================================================================
# Address Spaces
# =============================================================================
define space ram      type=ram_space      size=3  default;
define space register type=register_space size=1;

# =============================================================================
# Register Definitions
# =============================================================================

# = Accumulators =
# D = A:B (big-endian: A is high byte at lower offset, B is low byte)
define register offset=0x00 size=2 [ D ];
define register offset=0x00 size=1 [ A B ];
define register offset=0x02 size=2 [ E ];

# = Index Registers and Stack Pointer (16-bit) =
define register offset=0x10 size=2 [ IX IY IZ ];

# = Program Counter (full 24-bit for Ghidra's address space) =
define register offset=0x20 size=3 [ PC ];

# = Condition Code Register (16-bit) =
# Bit layout: [S:MV:H:EV:N:Z:V:C : IP2:IP1:IP0:SM:PK3:PK2:PK1:PK0]
define register offset=0x30 size=2 [ CCR ];

# = CCR flag bitranges =
# These map flag names directly onto CCR bits. The SLEIGH compiler generates
# the appropriate mask/shift operations automatically. Writing N_flag = 1
# is equivalent to CCR[11,1] = 1. No packCCR/unpackCCR ever needed.
# PK (bits 3:0) is kept as a separate register for cspec compatibility
# (PK is callee-saved but CCR is caller-saved).
define bitrange
    S_flag=CCR[15,1]  MV_flag=CCR[14,1] H_flag=CCR[13,1] EV_flag=CCR[12,1]
    N_flag=CCR[11,1]  Z_flag=CCR[10,1]  V_flag=CCR[9,1]  C_flag=CCR[8,1]
    IP_bits=CCR[5,3]  SM_flag=CCR[4,1];

# = Address Extension Fields (4-bit each, stored as 1-byte) =
define register offset=0x40 size=1 [ PK EK XK YK ZK ];


# = MAC Registers =
define register offset=0x60 size=2 [ HR IR ];
define register offset=0x64 size=4 [ AM ];       # using 32-bit for AM[31:0]
define register offset=0x68 size=1 [ AM_EXT ];   # AM[35:32] extension bits
define register offset=0x6A size=1 [ XMSK YMSK ];

# = Stack Pointer (3-byte composite for RAM address space compatibility) =
# SSP is the full 20-bit stack address. SK is the high byte (bank),
# SP is the lower 2 bytes. The cspec declares SSP as the stackpointer
# so Ghidra's stack analyzer sees a 3-byte pointer matching the 3-byte
# RAM space, eliminating ZEXT23 decompiler noise.
define register offset=0xA0 size=3 [ SSP ];
define register offset=0xA0 size=1 [ SK ];
define register offset=0xA1 size=2 [ SP ];

# = Temporary/internal registers =
define register offset=0x80 size=3 [ EADDR ];    # effective address scratchpad


# ================= Disassembly Context Register ====================================
# Used to resolve banked addresses at disassembly time.
# ctxEK: tracks the EK (data bank) extension field so that EXT16
#         addressing mode can compute full 20-bit addresses statically.
#         Default value set in pspec <context_data>.
#         noflow: prevents accidental propagation across branches;
# ================== the pspec default applies everywhere instead. ==================
define register offset=0x90 size=4 [ contextreg ];

define context contextreg
    ctxEK = (0,3) noflow
    ctxZK = (4,7) noflow
;

# =============================================================================
# Token Definitions (instruction byte stream)
# =============================================================================

# First opcode byte
define token opbyte (8)
    op8     = (0,7)
    op8_hi  = (4,7)
    op8_lo  = (0,3)
;

# Second opcode byte (for prefixed instructions or first operand)
define token opbyte2 (8)
    op8b     = (0,7)
    op8b_hi  = (4,7)
    op8b_lo  = (0,3)
;

# 8-bit immediate / offset / relative
define token imm8_tok (8)
    imm8     = (0,7)
    simm8    = (0,7) signed
    rel8     = (0,7) signed
    mask8    = (0,7)
;

# Second 8-bit token (e.g., for BRCLR/BRSET mask + offset patterns)
define token imm8_tok2 (8)
    imm8_2    = (0,7)
    simm8_2   = (0,7) signed
    rel8_2    = (0,7) signed
    mask8_2   = (0,7)
;

# Third 8-bit token (for BRCLR/BRSET IND8: mask + offset + rel8)
define token imm8_tok3 (8)
    imm8_3    = (0,7)
    rel8_3    = (0,7) signed
;

# 16-bit immediate / offset / address
define token imm16_tok (16)
    imm16    = (0,15)
    simm16   = (0,15) signed
    rel16    = (0,15) signed
    addr16   = (0,15)
;

# Second 16-bit token (for instructions with two 16-bit operands)
define token imm16_tok2 (16)
    imm16_2  = (0,15)
    simm16_2 = (0,15) signed
    rel16_2  = (0,15) signed
    addr16_2 = (0,15)
;

# 8-bit token for PSHM/PULM register mask
# Bit 0=D, 1=E, 2=IX, 3=IY, 4=IZ, 5=K, 6=CCR, 7=PC
define token regmask_tok (8)
    regmask  = (0,7)
    rm_d     = (0,0)
    rm_e     = (1,1)
    rm_ix    = (2,2)
    rm_iy    = (3,3)
    rm_iz    = (4,4)
    rm_k     = (5,5)
    rm_ccr   = (6,6)
    rm_pc    = (7,7)
;

# 8-bit token for MAC xo:yo offsets
define token macoff_tok (8)
    macoffs  = (0,7)
    mac_xo   = (4,7) signed
    mac_yo   = (0,3) signed
;

# 24-bit token for EXT20 / IND20 (zero-extended 20-bit in 3 bytes)
define token ext20_tok (24)
    ext20_full  = (0,23)
    ext20_bank  = (16,19)     # upper 4 bits of the 20-bit address
    ext20_addr  = (0,15)      # lower 16 bits
    ext20_pad   = (20,23)     # should be zero
    ext20_val   = (0,19) signed
;

# =============================================================================
# Attach register names to token fields (for instructions that select registers)
# =============================================================================

# =============================================================================
# P-Code Macros for common operations
# =============================================================================

# Construct the full CCR value for stack push by stitching PK into CCR.
# Uses a local to avoid mutating CCR (JSR/BSR/SWI do not affect the CCR).
# Flags (bits 15-4) are always current via bitrange; only PK (bits 3-0)
# needs to be stitched in from the separate PK register.
macro syncPushCCR(out) {
    out = (CCR & 0xFFF0) | zext(PK & 0x0F);
}

# After pulling a CCR word from the stack, sync PK from the pulled value.
# For RTI: also write the pulled value into CCR (restores all flags).
# For RTS: only extract PK; flags are not restored.
macro syncPullPK(val) {
    PK = val:1 & 0x0F;
}

# 8-bit addition flag computation (H, V, C)
macro addFlags(op1, op2) {
    H_flag = (((op1 & 0x0F) + (op2 & 0x0F)) >> 4) & 1;
    C_flag = carry(op1, op2);
    V_flag = scarry(op1, op2);
}

# 8-bit subtraction flag computation (V, C)
macro subFlags(op1, op2) {
    C_flag = (op1 < op2);
    V_flag = sborrow(op1, op2);
}

# 16-bit addition flag computation (V, C)
macro addFlags16(op1, op2) {
    C_flag = carry(op1, op2);
    V_flag = scarry(op1, op2);
}

# 16-bit subtraction flag computation (V, C)
macro subFlags16(op1, op2) {
    C_flag = (op1 < op2);
    V_flag = sborrow(op1, op2);
}

# Set N and Z flags for 8-bit result
macro setNZ8(result) {
    N_flag = (result s< 0);
    Z_flag = (result == 0);
}

# Set N and Z flags for 16-bit result
macro setNZ16(result) {
    N_flag = (result s< 0);
    Z_flag = (result == 0);
}

# Compute 20-bit effective address from extension field and 16-bit register
macro makeAddr20(ext4, reg16, out_addr) {
    out_addr = (zext(ext4) << 16) | zext(reg16);
}

# Push a 16-bit word onto the stack
macro push16(val) {
    SSP = SSP - 2;
    *:2 SSP = val;
}

# Pull a 16-bit word from the stack
macro pull16(val) {
    val = *:2 SSP;
    SSP = SSP + 2;
}

define pcodeop HaltUntilInterrupt;

# =============================================================================
# Addressing Mode Sub-Constructors
# =============================================================================

# = 8-bit Indexed (IND8,X / IND8,Y / IND8,Z) =
# Unsigned 8-bit offset added to index register + extension

IND8X: imm8^",X"  is imm8  { local ea:3 = (zext(XK:1) << 16) | zext(IX + zext(imm8:2)); export ea; }
IND8Y: imm8^",Y"  is imm8  { local ea:3 = (zext(YK:1) << 16) | zext(IY + zext(imm8:2)); export ea; }
IND8Z: imm8^",Z"  is imm8 & ctxZK  { local bank:1 = ctxZK; local ea:3 = (zext(bank) << 16) | zext(IZ + zext(imm8:2)); export ea; }

# = 16-bit Indexed (IND16,X / IND16,Y / IND16,Z) =
# Signed 16-bit offset added to index register + extension

IND16X: simm16^",X"  is simm16  { local ea:3 = (zext(XK:1) << 16) | zext(IX + simm16); export ea; }
IND16Y: simm16^",Y"  is simm16  { local ea:3 = (zext(YK:1) << 16) | zext(IY + simm16); export ea; }
IND16Z: simm16^",Z"  is simm16 & ctxZK  { local bank:1 = ctxZK; local ea:3 = (zext(bank) << 16) | zext(IZ + simm16); export ea; }

# = Extended (EXT) =
# EK concatenated with 16-bit address

# EXT16: Extended addressing with static bank resolution via ctxEK.
# The disassembly action computes the full 20-bit address at parse time,
# enabling Ghidra to create xrefs and clickable address links.
# Instructions dereference at their own size: *:1 EXT16 or *:2 EXT16.
EXT16: reloc  is addr16 & ctxEK  [ reloc = (ctxEK << 16) | addr16; ]  
{ 
    local hi:3 = zext(EK:1) << 16; 
    local lo:3 = zext(addr16:2); 
    local ea:3 = hi | lo; 
    export ea; 
}

# = Accumulator E Offset (E,X / E,Y / E,Z) =
# Sign-extended E added to index register

EOFFX: E,IX  is E & IX  { local ea:3 = (zext(XK:1) << 16) | zext(IX + E); export ea; }
EOFFY: E,IY  is E & IY  { local ea:3 = (zext(YK:1) << 16) | zext(IY + E); export ea; }
EOFFZ: E,IZ  is E & IZ & ctxZK  { local bank:1 = ctxZK; local ea:3 = (zext(bank) << 16) | zext(IZ + E); export ea; }

# = Relative Addressing =
# CPU16 pipeline: branch offsets are ALWAYS relative to inst_start + 6 (3-word prefetch)
REL8ADDR: reloc  is rel8   [ reloc = inst_start + 6 + rel8; ]   { export *:1 reloc; }
REL16ADDR: reloc is rel16  [ reloc = inst_start + 6 + rel16; ]  { export *:1 reloc; }

# = Branch targets for BRCLR/BRSET (use different token slots) =
BRREL8: reloc  is rel8_3  [ reloc = inst_start + 6 + rel8_3; ]  { export *:1 reloc; }
BRREL16: reloc is rel16_2 [ reloc = inst_start + 6 + rel16_2; ] { export *:1 reloc; }

# = Extended 20-bit (EXT20) - for JMP/JSR =
# ext20_pad must be 0 to disambiguate from BRSET/BRCLR sharing same opcodes
EXT20ADDR: reloc  is ext20_pad=0 & ext20_bank & ext20_addr [ reloc = (ext20_bank << 16) | ext20_addr; ]
    { export *:3 reloc; }

# = 20-bit Indexed (IND20) - for JMP/JSR =
# ext20_pad must be 0 to disambiguate from BRSET/BRCLR sharing the same opcodes.
#
# The 3-byte operand encodes a 20-bit UNSIGNED offset split as:
#   ext20_bank (bits 19-16) : the bank contribution (0–15)
#   ext20_addr (bits 15-0)  : the low 16-bit contribution
#
# EA = (XK:IX) + (ext20_bank << 16) | ext20_addr
#
# IMPORTANT: The offset is UNSIGNED here (zext, not sext).  With ext20_pad=0
# we can only decode non-negative offsets (0x00000–0x0FFFF).  Negative 20-bit
# offsets would require bits 23-20 to be set, violating ext20_pad=0, so they
# are handled by separate encodings (if present).  In practice, Chrysler JTEC+
# firmware (and most 68HC16 banked code) uses this mode exclusively to add a
# positive bank constant (+0x10000, +0x20000, +0x30000) to the loaded pointer.
#
# Display: "bank:addr,X" mirrors EXT20ADDR notation for consistency and makes
# the bank contribution immediately visible to the analyst.  
IND20X: ext20_bank^":"^ext20_addr^",X"  is ext20_pad=0 & ext20_bank & ext20_addr & ext20_val {
    local base:3 = (zext(XK:1) << 16) | zext(IX:2);
    local ea:3 = base + ext20_val;
    export ea;
}

IND20Y: ext20_bank^":"^ext20_addr^",Y"  is ext20_pad=0 & ext20_bank & ext20_addr & ext20_val {
    local base:3 = (zext(YK:1) << 16) | zext(IY:2);
    local ea:3 = base + ext20_val;
    export ea;
}

IND20Z: ext20_bank^":"^ext20_addr^",Z"  is ext20_pad=0 & ext20_bank & ext20_addr & ext20_val {
    local base:3 = (zext(ZK:1) << 16) | zext(IZ:2);
    local ea:3 = base + ext20_val;
    export ea;
}


# =============================================================================
# INSTRUCTION DEFINITIONS
# =============================================================================
# Organized by opcode pages and functional groups
# Opcode notation from CPU16RM:
#   Page 1: single byte opcode
#   Page 2: prefix 0x17 + opcode byte
#   Page 3: prefix 0x27 + opcode byte
#   Page 4: prefix 0x37 + opcode byte
# =============================================================================


# ============================================================================
# SECTION: 8-BIT ACCUMULATOR A INSTRUCTIONS (Page 1: 4x, Page 2: 174x, Page 3: 274x)
# Pattern: 4x=IND8,X  5x=IND8,Y  6x=IND8,Z  7x=IMM8
#          174x=IND16,X  175x=IND16,Y  176x=IND16,Z  177x=EXT
#          274x=E,X  275x=E,Y  276x=E,Z
# Lower nibble determines operation:
#   0=SUBA 1=ADDA 2=SBCA 3=ADCA 4=UNUSED 5=LDAA 6=ANDA 7=ORAA
#   8=CMPA 9=BITA A=STAA B=UNUSED C=UNUSED D=UNUSED E=UNUSED F=UNUSED
# ============================================================================

# = SUBA: (A) - (M) => A =
:SUBA IND8X     is op8=0x40; IND8X     { local val:1 = *:1 IND8X; subFlags(A, val); A = A - val; setNZ8(A); }
:SUBA IND8Y     is op8=0x50; IND8Y     { local val:1 = *:1 IND8Y; subFlags(A, val); A = A - val; setNZ8(A); }
:SUBA IND8Z     is op8=0x60; IND8Z     { local val:1 = *:1 IND8Z; subFlags(A, val); A = A - val; setNZ8(A); }
:SUBA "#"^imm8  is op8=0x70; imm8      { subFlags(A, imm8); A = A - imm8; setNZ8(A); }
:SUBA IND16X    is op8=0x17; op8b=0x40; IND16X  { local val:1 = *:1 IND16X; subFlags(A, val); A = A - val; setNZ8(A); }
:SUBA IND16Y    is op8=0x17; op8b=0x50; IND16Y  { local val:1 = *:1 IND16Y; subFlags(A, val); A = A - val; setNZ8(A); }
:SUBA IND16Z    is op8=0x17; op8b=0x60; IND16Z  { local val:1 = *:1 IND16Z; subFlags(A, val); A = A - val; setNZ8(A); }
:SUBA EXT16     is op8=0x17; op8b=0x70; EXT16   { local val:1 = *:1 EXT16;  subFlags(A, val); A = A - val; setNZ8(A); }
:SUBA EOFFX     is op8=0x27; op8b=0x40; EOFFX   { local val:1 = *:1 EOFFX;  subFlags(A, val); A = A - val; setNZ8(A); }
:SUBA EOFFY     is op8=0x27; op8b=0x50; EOFFY   { local val:1 = *:1 EOFFY;  subFlags(A, val); A = A - val; setNZ8(A); }
:SUBA EOFFZ     is op8=0x27; op8b=0x60; EOFFZ   { local val:1 = *:1 EOFFZ;  subFlags(A, val); A = A - val; setNZ8(A); }

# = ADDA: (A) + (M) => A =
:ADDA IND8X     is op8=0x41; IND8X     { local val:1 = *:1 IND8X; addFlags(A, val); A = A + val; setNZ8(A); }
:ADDA IND8Y     is op8=0x51; IND8Y     { local val:1 = *:1 IND8Y; addFlags(A, val); A = A + val; setNZ8(A); }
:ADDA IND8Z     is op8=0x61; IND8Z     { local val:1 = *:1 IND8Z; addFlags(A, val); A = A + val; setNZ8(A); }
:ADDA "#"^imm8  is op8=0x71; imm8      { addFlags(A, imm8); A = A + imm8; setNZ8(A); }
:ADDA IND16X    is op8=0x17; op8b=0x41; IND16X  { local val:1 = *:1 IND16X; addFlags(A, val); A = A + val; setNZ8(A); }
:ADDA IND16Y    is op8=0x17; op8b=0x51; IND16Y  { local val:1 = *:1 IND16Y; addFlags(A, val); A = A + val; setNZ8(A); }
:ADDA IND16Z    is op8=0x17; op8b=0x61; IND16Z  { local val:1 = *:1 IND16Z; addFlags(A, val); A = A + val; setNZ8(A); }
:ADDA EXT16     is op8=0x17; op8b=0x71; EXT16   { local val:1 = *:1 EXT16;  addFlags(A, val); A = A + val; setNZ8(A); }
:ADDA EOFFX     is op8=0x27; op8b=0x41; EOFFX   { local val:1 = *:1 EOFFX;  addFlags(A, val); A = A + val; setNZ8(A); }
:ADDA EOFFY     is op8=0x27; op8b=0x51; EOFFY   { local val:1 = *:1 EOFFY;  addFlags(A, val); A = A + val; setNZ8(A); }
:ADDA EOFFZ     is op8=0x27; op8b=0x61; EOFFZ   { local val:1 = *:1 EOFFZ;  addFlags(A, val); A = A + val; setNZ8(A); }

# = SBCA: (A) - (M) - C => A =
:SBCA IND8X     is op8=0x42; IND8X     { local val:1 = *:1 IND8X; local c:1 = C_flag; subFlags(A, val+c); A = A - val - c; setNZ8(A); }
:SBCA IND8Y     is op8=0x52; IND8Y     { local val:1 = *:1 IND8Y; local c:1 = C_flag; subFlags(A, val+c); A = A - val - c; setNZ8(A); }
:SBCA IND8Z     is op8=0x62; IND8Z     { local val:1 = *:1 IND8Z; local c:1 = C_flag; subFlags(A, val+c); A = A - val - c; setNZ8(A); }
:SBCA "#"^imm8  is op8=0x72; imm8      { local c:1 = C_flag; subFlags(A, imm8+c); A = A - imm8 - c; setNZ8(A); }
:SBCA IND16X    is op8=0x17; op8b=0x42; IND16X  { local val:1 = *:1 IND16X; local c:1 = C_flag; subFlags(A, val+c); A = A - val - c; setNZ8(A); }
:SBCA IND16Y    is op8=0x17; op8b=0x52; IND16Y  { local val:1 = *:1 IND16Y; local c:1 = C_flag; subFlags(A, val+c); A = A - val - c; setNZ8(A); }
:SBCA IND16Z    is op8=0x17; op8b=0x62; IND16Z  { local val:1 = *:1 IND16Z; local c:1 = C_flag; subFlags(A, val+c); A = A - val - c; setNZ8(A); }
:SBCA EXT16     is op8=0x17; op8b=0x72; EXT16   { local val:1 = *:1 EXT16;  local c:1 = C_flag; subFlags(A, val+c); A = A - val - c; setNZ8(A); }
:SBCA EOFFX     is op8=0x27; op8b=0x42; EOFFX   { local val:1 = *:1 EOFFX;  local c:1 = C_flag; subFlags(A, val+c); A = A - val - c; setNZ8(A); }
:SBCA EOFFY     is op8=0x27; op8b=0x52; EOFFY   { local val:1 = *:1 EOFFY;  local c:1 = C_flag; subFlags(A, val+c); A = A - val - c; setNZ8(A); }
:SBCA EOFFZ     is op8=0x27; op8b=0x62; EOFFZ   { local val:1 = *:1 EOFFZ;  local c:1 = C_flag; subFlags(A, val+c); A = A - val - c; setNZ8(A); }

# = ADCA: (A) + (M) + C => A =
:ADCA IND8X     is op8=0x43; IND8X     { local val:1 = *:1 IND8X; local c:1 = C_flag; addFlags(A, val+c); A = A + val + c; setNZ8(A); }
:ADCA IND8Y     is op8=0x53; IND8Y     { local val:1 = *:1 IND8Y; local c:1 = C_flag; addFlags(A, val+c); A = A + val + c; setNZ8(A); }
:ADCA IND8Z     is op8=0x63; IND8Z     { local val:1 = *:1 IND8Z; local c:1 = C_flag; addFlags(A, val+c); A = A + val + c; setNZ8(A); }
:ADCA "#"^imm8  is op8=0x73; imm8      { local c:1 = C_flag; addFlags(A, imm8+c); A = A + imm8 + c; setNZ8(A); }
:ADCA IND16X    is op8=0x17; op8b=0x43; IND16X  { local val:1 = *:1 IND16X; local c:1 = C_flag; addFlags(A, val+c); A = A + val + c; setNZ8(A); }
:ADCA IND16Y    is op8=0x17; op8b=0x53; IND16Y  { local val:1 = *:1 IND16Y; local c:1 = C_flag; addFlags(A, val+c); A = A + val + c; setNZ8(A); }
:ADCA IND16Z    is op8=0x17; op8b=0x63; IND16Z  { local val:1 = *:1 IND16Z; local c:1 = C_flag; addFlags(A, val+c); A = A + val + c; setNZ8(A); }
:ADCA EXT16     is op8=0x17; op8b=0x73; EXT16   { local val:1 = *:1 EXT16;  local c:1 = C_flag; addFlags(A, val+c); A = A + val + c; setNZ8(A); }
:ADCA EOFFX     is op8=0x27; op8b=0x43; EOFFX   { local val:1 = *:1 EOFFX;  local c:1 = C_flag; addFlags(A, val+c); A = A + val + c; setNZ8(A); }
:ADCA EOFFY     is op8=0x27; op8b=0x53; EOFFY   { local val:1 = *:1 EOFFY;  local c:1 = C_flag; addFlags(A, val+c); A = A + val + c; setNZ8(A); }
:ADCA EOFFZ     is op8=0x27; op8b=0x63; EOFFZ   { local val:1 = *:1 EOFFZ;  local c:1 = C_flag; addFlags(A, val+c); A = A + val + c; setNZ8(A); }

# = LDAA: (M) => A =
:LDAA IND8X     is op8=0x45; IND8X     { A = *:1 IND8X; setNZ8(A); V_flag = 0; }
:LDAA IND8Y     is op8=0x55; IND8Y     { A = *:1 IND8Y; setNZ8(A); V_flag = 0; }
