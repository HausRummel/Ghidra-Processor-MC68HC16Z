:ORAA EOFFZ     is op8=0x27; op8b=0x67; EOFFZ   { A = A | (*:1 EOFFZ);  setNZ8(A); V_flag = 0; }

# = CMPA: (A) - (M) [compare, no store] =
:CMPA IND8X     is op8=0x48; IND8X     { local val:1 = *:1 IND8X; local tmp:1 = A - val; subFlags(A, val); setNZ8(tmp); }
:CMPA IND8Y     is op8=0x58; IND8Y     { local val:1 = *:1 IND8Y; local tmp:1 = A - val; subFlags(A, val); setNZ8(tmp); }
:CMPA IND8Z     is op8=0x68; IND8Z     { local val:1 = *:1 IND8Z; local tmp:1 = A - val; subFlags(A, val); setNZ8(tmp); }
:CMPA "#"^imm8  is op8=0x78; imm8      { local tmp:1 = A - imm8; subFlags(A, imm8); setNZ8(tmp); }
:CMPA IND16X    is op8=0x17; op8b=0x48; IND16X  { local val:1 = *:1 IND16X; local tmp:1 = A - val; subFlags(A, val); setNZ8(tmp); }
:CMPA IND16Y    is op8=0x17; op8b=0x58; IND16Y  { local val:1 = *:1 IND16Y; local tmp:1 = A - val; subFlags(A, val); setNZ8(tmp); }
:CMPA IND16Z    is op8=0x17; op8b=0x68; IND16Z  { local val:1 = *:1 IND16Z; local tmp:1 = A - val; subFlags(A, val); setNZ8(tmp); }
:CMPA EXT16     is op8=0x17; op8b=0x78; EXT16   { local val:1 = *:1 EXT16;  local tmp:1 = A - val; subFlags(A, val); setNZ8(tmp); }
:CMPA EOFFX     is op8=0x27; op8b=0x48; EOFFX   { local val:1 = *:1 EOFFX;  local tmp:1 = A - val; subFlags(A, val); setNZ8(tmp); }
:CMPA EOFFY     is op8=0x27; op8b=0x58; EOFFY   { local val:1 = *:1 EOFFY;  local tmp:1 = A - val; subFlags(A, val); setNZ8(tmp); }
:CMPA EOFFZ     is op8=0x27; op8b=0x68; EOFFZ   { local val:1 = *:1 EOFFZ;  local tmp:1 = A - val; subFlags(A, val); setNZ8(tmp); }

# = BITA: (A) & (M) [test, no store] =
:BITA IND8X     is op8=0x49; IND8X     { local tmp:1 = A & (*:1 IND8X); setNZ8(tmp); V_flag = 0; }
:BITA IND8Y     is op8=0x59; IND8Y     { local tmp:1 = A & (*:1 IND8Y); setNZ8(tmp); V_flag = 0; }
:BITA IND8Z     is op8=0x69; IND8Z     { local tmp:1 = A & (*:1 IND8Z); setNZ8(tmp); V_flag = 0; }
