:LDAB IND16Y    is op8=0x17; op8b=0xD5; IND16Y  { B = *:1 IND16Y; setNZ8(B); V_flag = 0; }
:LDAB IND16Z    is op8=0x17; op8b=0xE5; IND16Z  { B = *:1 IND16Z; setNZ8(B); V_flag = 0; }
:LDAB EXT16     is op8=0x17; op8b=0xF5; EXT16   { B = *:1 EXT16;  setNZ8(B); V_flag = 0; }
:LDAB EOFFX     is op8=0x27; op8b=0xC5; EOFFX   { B = *:1 EOFFX;  setNZ8(B); V_flag = 0; }
:LDAB EOFFY     is op8=0x27; op8b=0xD5; EOFFY   { B = *:1 EOFFY;  setNZ8(B); V_flag = 0; }
:LDAB EOFFZ     is op8=0x27; op8b=0xE5; EOFFZ   { B = *:1 EOFFZ;  setNZ8(B); V_flag = 0; }

# = ANDB =
:ANDB IND8X     is op8=0xC6; IND8X     { B = B & (*:1 IND8X); setNZ8(B); V_flag = 0; }
:ANDB IND8Y     is op8=0xD6; IND8Y     { B = B & (*:1 IND8Y); setNZ8(B); V_flag = 0; }
:ANDB IND8Z     is op8=0xE6; IND8Z     { B = B & (*:1 IND8Z); setNZ8(B); V_flag = 0; }
