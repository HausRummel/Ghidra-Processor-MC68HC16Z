:BITA EOFFX     is op8=0x27; op8b=0x49; EOFFX   { local tmp:1 = A & (*:1 EOFFX);  setNZ8(tmp); V_flag = 0; }
:BITA EOFFY     is op8=0x27; op8b=0x59; EOFFY   { local tmp:1 = A & (*:1 EOFFY);  setNZ8(tmp); V_flag = 0; }
:BITA EOFFZ     is op8=0x27; op8b=0x69; EOFFZ   { local tmp:1 = A & (*:1 EOFFZ);  setNZ8(tmp); V_flag = 0; }

# = EORA: (A) ^ (M) => A =
:EORA IND8X     is op8=0x44; IND8X     { A = A ^ (*:1 IND8X); setNZ8(A); V_flag = 0; }
:EORA IND8Y     is op8=0x54; IND8Y     { A = A ^ (*:1 IND8Y); setNZ8(A); V_flag = 0; }
:EORA IND8Z     is op8=0x64; IND8Z     { A = A ^ (*:1 IND8Z); setNZ8(A); V_flag = 0; }
