:ORAA IND16Y    is op8=0x17; op8b=0x57; IND16Y  { A = A | (*:1 IND16Y); setNZ8(A); V_flag = 0; }
:ORAA IND16Z    is op8=0x17; op8b=0x67; IND16Z  { A = A | (*:1 IND16Z); setNZ8(A); V_flag = 0; }
:ORAA EXT16     is op8=0x17; op8b=0x77; EXT16   { A = A | (*:1 EXT16);  setNZ8(A); V_flag = 0; }
