:EORA IND16Y    is op8=0x17; op8b=0x54; IND16Y  { A = A ^ (*:1 IND16Y); setNZ8(A); V_flag = 0; }
:EORA IND16Z    is op8=0x17; op8b=0x64; IND16Z  { A = A ^ (*:1 IND16Z); setNZ8(A); V_flag = 0; }
:EORA EXT16     is op8=0x17; op8b=0x74; EXT16   { A = A ^ (*:1 EXT16);  setNZ8(A); V_flag = 0; }
