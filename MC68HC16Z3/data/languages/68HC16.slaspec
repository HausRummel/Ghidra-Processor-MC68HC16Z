# = ORAA: (A) | (M) => A =
:ORAA IND8X     is op8=0x47; IND8X     { A = A | (*:1 IND8X); setNZ8(A); V_flag = 0; }
:ORAA IND8Y     is op8=0x57; IND8Y     { A = A | (*:1 IND8Y); setNZ8(A); V_flag = 0; }
:ORAA IND8Z     is op8=0x67; IND8Z     { A = A | (*:1 IND8Z); setNZ8(A); V_flag = 0; }
:ORAA "#"^imm8  is op8=0x77; imm8      { A = A | imm8; setNZ8(A); V_flag = 0; }
