:ADCB IND16X    is op8=0x17; op8b=0xC3; IND16X  { local val:1 = *:1 IND16X; local c:1 = C_flag; addFlags(B, val+c); B = B + val + c; setNZ8(B); }
:ADCB IND16Y    is op8=0x17; op8b=0xD3; IND16Y  { local val:1 = *:1 IND16Y; local c:1 = C_flag; addFlags(B, val+c); B = B + val + c; setNZ8(B); }
:ADCB IND16Z    is op8=0x17; op8b=0xE3; IND16Z  { local val:1 = *:1 IND16Z; local c:1 = C_flag; addFlags(B, val+c); B = B + val + c; setNZ8(B); }
:ADCB EXT16     is op8=0x17; op8b=0xF3; EXT16   { local val:1 = *:1 EXT16;  local c:1 = C_flag; addFlags(B, val+c); B = B + val + c; setNZ8(B); }

# = LDAB =
:LDAB IND8X     is op8=0xC5; IND8X     { B = *:1 IND8X; setNZ8(B); V_flag = 0; }
:LDAB IND8Y     is op8=0xD5; IND8Y     { B = *:1 IND8Y; setNZ8(B); V_flag = 0; }
:LDAB IND8Z     is op8=0xE5; IND8Z     { B = *:1 IND8Z; setNZ8(B); V_flag = 0; }
