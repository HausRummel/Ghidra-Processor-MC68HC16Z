:LDAA EXT16     is op8=0x17; op8b=0x75; EXT16   { A = *:1 EXT16;  setNZ8(A); V_flag = 0; }
:LDAA EOFFX     is op8=0x27; op8b=0x45; EOFFX   { A = *:1 EOFFX;  setNZ8(A); V_flag = 0; }
:LDAA EOFFY     is op8=0x27; op8b=0x55; EOFFY   { A = *:1 EOFFY;  setNZ8(A); V_flag = 0; }
:LDAA EOFFZ     is op8=0x27; op8b=0x65; EOFFZ   { A = *:1 EOFFZ;  setNZ8(A); V_flag = 0; }

# = ANDA: (A) & (M) => A =
:ANDA IND8X     is op8=0x46; IND8X     { A = A & (*:1 IND8X); setNZ8(A); V_flag = 0; }
