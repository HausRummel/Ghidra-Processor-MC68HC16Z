:STAA EOFFY     is op8=0x27; op8b=0x5A; EOFFY   { *:1 EOFFY = A;  setNZ8(A); V_flag = 0; }
:STAA EOFFZ     is op8=0x27; op8b=0x6A; EOFFZ   { *:1 EOFFZ = A;  setNZ8(A); V_flag = 0; }


# ============================================================================
# SECTION: 8-BIT ACCUMULATOR B INSTRUCTIONS (Page 1: Cx-Fx, Page 2: 17Cx-17Fx, Page 3: 27Cx-27Fx)
