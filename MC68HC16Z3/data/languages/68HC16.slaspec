# ============================================================================
# SECTION: BCLRW - Clear Bit(s) in memory word
# (M:M+1) & ~(Mask16) => M:M+1
# Flags: N=delta Z=delta V=0 C=--
# All modes use page 3 prefix (0x27)
# Encoding: 27 opcode offset16 mask16
# ============================================================================

# BCLRW IND16,X: 27 08 gggg mmmm
:BCLRW simm16^",X,#"^imm16_2  is op8=0x27; op8b=0x08; simm16; imm16_2 {
    local ea:3 = (zext(XK:1) << 16) | zext(IX + simm16);
    local val:2 = *:2 ea;
    val = val & (~imm16_2);
    *:2 ea = val;
    setNZ16(val); V_flag = 0;
}

# BCLRW IND16,Y: 27 18 gggg mmmm
:BCLRW simm16^",Y,#"^imm16_2  is op8=0x27; op8b=0x18; simm16; imm16_2 {
    local ea:3 = (zext(YK:1) << 16) | zext(IY + simm16);
    local val:2 = *:2 ea;
    val = val & (~imm16_2);
    *:2 ea = val;
    setNZ16(val); V_flag = 0;
}

# BCLRW IND16,Z: 27 28 gggg mmmm
:BCLRW simm16^",Z,#"^imm16_2  is op8=0x27; op8b=0x28; simm16; imm16_2 & ctxZK{
    local bank:1 = ctxZK;
    local ea:3 = (zext(bank) << 16) | zext(IZ + simm16);
    local val:2 = *:2 ea;
    val = val & (~imm16_2);
    *:2 ea = val;
    setNZ16(val); V_flag = 0;
}

# BCLRW EXT: 27 38 hh ll mmmm
:BCLRW addr16^",#"^imm16_2  is op8=0x27; op8b=0x38; addr16; imm16_2 {
    local ea:3 = (zext(EK:1) << 16) | zext(addr16:2);
    local val:2 = *:2 ea;
    val = val & (~imm16_2);
    *:2 ea = val;
    setNZ16(val); V_flag = 0;
}


# ============================================================================
# SECTION: BSETW - Set Bit(s) in memory word
# (M:M+1) | (Mask16) => M:M+1
# Flags: N=delta Z=delta V=0 C=--
# ============================================================================

# BSETW IND16,X: 27 09 gggg mmmm
:BSETW simm16^",X,#"^imm16_2  is op8=0x27; op8b=0x09; simm16; imm16_2 {
    local ea:3 = (zext(XK:1) << 16) | zext(IX + simm16);
    local val:2 = *:2 ea;
