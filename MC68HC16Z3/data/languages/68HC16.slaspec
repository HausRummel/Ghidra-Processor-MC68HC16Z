:BITA IND16Y    is op8=0x17; op8b=0x59; IND16Y  { local tmp:1 = A & (*:1 IND16Y); setNZ8(tmp); V_flag = 0; }
:BITA IND16Z    is op8=0x17; op8b=0x69; IND16Z  { local tmp:1 = A & (*:1 IND16Z); setNZ8(tmp); V_flag = 0; }
