:ANDB IND16Y    is op8=0x17; op8b=0xD6; IND16Y  { B = B & (*:1 IND16Y); setNZ8(B); V_flag = 0; }
:ANDB IND16Z    is op8=0x17; op8b=0xE6; IND16Z  { B = B & (*:1 IND16Z); setNZ8(B); V_flag = 0; }
:ANDB EXT16     is op8=0x17; op8b=0xF6; EXT16   { B = B & (*:1 EXT16);  setNZ8(B); V_flag = 0; }

# = ORAB =
:ORAB IND8X     is op8=0xC7; IND8X     { B = B | (*:1 IND8X); setNZ8(B); V_flag = 0; }
:ORAB IND8Y     is op8=0xD7; IND8Y     { B = B | (*:1 IND8Y); setNZ8(B); V_flag = 0; }
:ORAB IND8Z     is op8=0xE7; IND8Z     { B = B | (*:1 IND8Z); setNZ8(B); V_flag = 0; }
:ORAB "#"^imm8  is op8=0xF7; imm8      { B = B | imm8; setNZ8(B); V_flag = 0; }
:ORAB IND16X    is op8=0x17; op8b=0xC7; IND16X  { B = B | (*:1 IND16X); setNZ8(B); V_flag = 0; }
:ORAB IND16Y    is op8=0x17; op8b=0xD7; IND16Y  { B = B | (*:1 IND16Y); setNZ8(B); V_flag = 0; }
:ORAB IND16Z    is op8=0x17; op8b=0xE7; IND16Z  { B = B | (*:1 IND16Z); setNZ8(B); V_flag = 0; }
:ORAB EXT16     is op8=0x17; op8b=0xF7; EXT16   { B = B | (*:1 EXT16);  setNZ8(B); V_flag = 0; }

# = CMPB =
:CMPB IND8X     is op8=0xC8; IND8X     { local val:1 = *:1 IND8X; local tmp:1 = B - val; subFlags(B, val); setNZ8(tmp); }
:CMPB IND8Y     is op8=0xD8; IND8Y     { local val:1 = *:1 IND8Y; local tmp:1 = B - val; subFlags(B, val); setNZ8(tmp); }
:CMPB IND8Z     is op8=0xE8; IND8Z     { local val:1 = *:1 IND8Z; local tmp:1 = B - val; subFlags(B, val); setNZ8(tmp); }
:CMPB "#"^imm8  is op8=0xF8; imm8      { local tmp:1 = B - imm8; subFlags(B, imm8); setNZ8(tmp); }
:CMPB IND16X    is op8=0x17; op8b=0xC8; IND16X  { local val:1 = *:1 IND16X; local tmp:1 = B - val; subFlags(B, val); setNZ8(tmp); }
:CMPB IND16Y    is op8=0x17; op8b=0xD8; IND16Y  { local val:1 = *:1 IND16Y; local tmp:1 = B - val; subFlags(B, val); setNZ8(tmp); }
:CMPB IND16Z    is op8=0x17; op8b=0xE8; IND16Z  { local val:1 = *:1 IND16Z; local tmp:1 = B - val; subFlags(B, val); setNZ8(tmp); }
:CMPB EXT16     is op8=0x17; op8b=0xF8; EXT16   { local val:1 = *:1 EXT16;  local tmp:1 = B - val; subFlags(B, val); setNZ8(tmp); }

# = BITB =
:BITB IND8X     is op8=0xC9; IND8X     { local tmp:1 = B & (*:1 IND8X); setNZ8(tmp); V_flag = 0; }
:BITB IND8Y     is op8=0xD9; IND8Y     { local tmp:1 = B & (*:1 IND8Y); setNZ8(tmp); V_flag = 0; }
:BITB IND8Z     is op8=0xE9; IND8Z     { local tmp:1 = B & (*:1 IND8Z); setNZ8(tmp); V_flag = 0; }
:BITB "#"^imm8  is op8=0xF9; imm8      { local tmp:1 = B & imm8; setNZ8(tmp); V_flag = 0; }
:BITB IND16X    is op8=0x17; op8b=0xC9; IND16X  { local tmp:1 = B & (*:1 IND16X); setNZ8(tmp); V_flag = 0; }
:BITB IND16Y    is op8=0x17; op8b=0xD9; IND16Y  { local tmp:1 = B & (*:1 IND16Y); setNZ8(tmp); V_flag = 0; }
:BITB IND16Z    is op8=0x17; op8b=0xE9; IND16Z  { local tmp:1 = B & (*:1 IND16Z); setNZ8(tmp); V_flag = 0; }
:BITB EXT16     is op8=0x17; op8b=0xF9; EXT16   { local tmp:1 = B & (*:1 EXT16);  setNZ8(tmp); V_flag = 0; }

# = EORB =
:EORB IND8X     is op8=0xC4; IND8X     { B = B ^ (*:1 IND8X); setNZ8(B); V_flag = 0; }
:EORB IND8Y     is op8=0xD4; IND8Y     { B = B ^ (*:1 IND8Y); setNZ8(B); V_flag = 0; }
:EORB IND8Z     is op8=0xE4; IND8Z     { B = B ^ (*:1 IND8Z); setNZ8(B); V_flag = 0; }
:EORB "#"^imm8  is op8=0xF4; imm8      { B = B ^ imm8; setNZ8(B); V_flag = 0; }
:EORB IND16X    is op8=0x17; op8b=0xC4; IND16X  { B = B ^ (*:1 IND16X); setNZ8(B); V_flag = 0; }
:EORB IND16Y    is op8=0x17; op8b=0xD4; IND16Y  { B = B ^ (*:1 IND16Y); setNZ8(B); V_flag = 0; }
:EORB IND16Z    is op8=0x17; op8b=0xE4; IND16Z  { B = B ^ (*:1 IND16Z); setNZ8(B); V_flag = 0; }
:EORB EXT16     is op8=0x17; op8b=0xF4; EXT16   { B = B ^ (*:1 EXT16);  setNZ8(B); V_flag = 0; }

# = STAB =
:STAB IND8X     is op8=0xCA; IND8X     { *:1 IND8X = B; setNZ8(B); V_flag = 0; }
:STAB IND8Y     is op8=0xDA; IND8Y     { *:1 IND8Y = B; setNZ8(B); V_flag = 0; }
:STAB IND8Z     is op8=0xEA; IND8Z     { *:1 IND8Z = B; setNZ8(B); V_flag = 0; }
:STAB IND16X    is op8=0x17; op8b=0xCA; IND16X  { *:1 IND16X = B; setNZ8(B); V_flag = 0; }
:STAB IND16Y    is op8=0x17; op8b=0xDA; IND16Y  { *:1 IND16Y = B; setNZ8(B); V_flag = 0; }
:STAB IND16Z    is op8=0x17; op8b=0xEA; IND16Z  { *:1 IND16Z = B; setNZ8(B); V_flag = 0; }
:STAB EXT16     is op8=0x17; op8b=0xFA; EXT16   { *:1 EXT16 = B;  setNZ8(B); V_flag = 0; }
:STAB EOFFX     is op8=0x27; op8b=0xCA; EOFFX   { *:1 EOFFX = B;  setNZ8(B); V_flag = 0; }
:STAB EOFFY     is op8=0x27; op8b=0xDA; EOFFY   { *:1 EOFFY = B;  setNZ8(B); V_flag = 0; }
:STAB EOFFZ     is op8=0x27; op8b=0xEA; EOFFZ   { *:1 EOFFZ = B;  setNZ8(B); V_flag = 0; }


# ============================================================================
# SECTION: 16-BIT ACCUMULATOR D INSTRUCTIONS
# Pattern: 8x=IND8,X  9x=IND8,Y  Ax=IND8,Z
#          37Bx=IMM16  37Cx=IND16,X  37Dx=IND16,Y  37Ex=IND16,Z  37Fx=EXT
#          278x=E,X  279x=E,Y  27Ax=E,Z
# ============================================================================

# = SUBD: (D) - (M:M+1) => D =
:SUBD IND8X     is op8=0x80; IND8X     { local val:2 = *:2 IND8X; subFlags16(D, val); D = D - val; setNZ16(D); }
:SUBD IND8Y     is op8=0x90; IND8Y     { local val:2 = *:2 IND8Y; subFlags16(D, val); D = D - val; setNZ16(D); }
:SUBD IND8Z     is op8=0xA0; IND8Z     { local val:2 = *:2 IND8Z; subFlags16(D, val); D = D - val; setNZ16(D); }
:SUBD "#"^imm16 is op8=0x37; op8b=0xB0; imm16  { local val:2 = imm16; subFlags16(D, val); D = D - val; setNZ16(D); }
:SUBD IND16X    is op8=0x37; op8b=0xC0; IND16X  { local val:2 = *:2 IND16X; subFlags16(D, val); D = D - val; setNZ16(D); }
:SUBD IND16Y    is op8=0x37; op8b=0xD0; IND16Y  { local val:2 = *:2 IND16Y; subFlags16(D, val); D = D - val; setNZ16(D); }
:SUBD IND16Z    is op8=0x37; op8b=0xE0; IND16Z  { local val:2 = *:2 IND16Z; subFlags16(D, val); D = D - val; setNZ16(D); }
:SUBD EXT16     is op8=0x37; op8b=0xF0; EXT16   { local val:2 = *:2 EXT16;  subFlags16(D, val); D = D - val; setNZ16(D); }
:SUBD EOFFX     is op8=0x27; op8b=0x80; EOFFX   { local val:2 = *:2 EOFFX;  subFlags16(D, val); D = D - val; setNZ16(D); }
:SUBD EOFFY     is op8=0x27; op8b=0x90; EOFFY   { local val:2 = *:2 EOFFY;  subFlags16(D, val); D = D - val; setNZ16(D); }
:SUBD EOFFZ     is op8=0x27; op8b=0xA0; EOFFZ   { local val:2 = *:2 EOFFZ;  subFlags16(D, val); D = D - val; setNZ16(D); }

# = ADDD: (D) + (M:M+1) => D =
# Note: ADDD has both IMM8 (sign-extended) and IMM16 forms
:ADDD IND8X     is op8=0x81; IND8X     { local val:2 = *:2 IND8X; addFlags16(D, val); D = D + val; setNZ16(D); }
:ADDD IND8Y     is op8=0x91; IND8Y     { local val:2 = *:2 IND8Y; addFlags16(D, val); D = D + val; setNZ16(D); }
:ADDD IND8Z     is op8=0xA1; IND8Z     { local val:2 = *:2 IND8Z; addFlags16(D, val); D = D + val; setNZ16(D); }
:ADDD "#"^imm8  is op8=0xFC; imm8      { local val:2 = sext(imm8:1); addFlags16(D, val); D = D + val; setNZ16(D); }
:ADDD "#"^imm16 is op8=0x37; op8b=0xB1; imm16  { local val:2 = imm16; addFlags16(D, val); D = D + val; setNZ16(D); }
:ADDD IND16X    is op8=0x37; op8b=0xC1; IND16X  { local val:2 = *:2 IND16X; addFlags16(D, val); D = D + val; setNZ16(D); }
:ADDD IND16Y    is op8=0x37; op8b=0xD1; IND16Y  { local val:2 = *:2 IND16Y; addFlags16(D, val); D = D + val; setNZ16(D); }
:ADDD IND16Z    is op8=0x37; op8b=0xE1; IND16Z  { local val:2 = *:2 IND16Z; addFlags16(D, val); D = D + val; setNZ16(D); }
:ADDD EXT16     is op8=0x37; op8b=0xF1; EXT16   { local val:2 = *:2 EXT16;  addFlags16(D, val); D = D + val; setNZ16(D); }
:ADDD EOFFX     is op8=0x27; op8b=0x81; EOFFX   { local val:2 = *:2 EOFFX;  addFlags16(D, val); D = D + val; setNZ16(D); }
:ADDD EOFFY     is op8=0x27; op8b=0x91; EOFFY   { local val:2 = *:2 EOFFY;  addFlags16(D, val); D = D + val; setNZ16(D); }
:ADDD EOFFZ     is op8=0x27; op8b=0xA1; EOFFZ   { local val:2 = *:2 EOFFZ;  addFlags16(D, val); D = D + val; setNZ16(D); }

# = SBCD: (D) - (M:M+1) - C => D =
:SBCD IND8X     is op8=0x82; IND8X     { local val:2 = *:2 IND8X; local c:2 = zext(C_flag); subFlags16(D, val+c); D = D - val - c; setNZ16(D); }
:SBCD IND8Y     is op8=0x92; IND8Y     { local val:2 = *:2 IND8Y; local c:2 = zext(C_flag); subFlags16(D, val+c); D = D - val - c; setNZ16(D); }
:SBCD IND8Z     is op8=0xA2; IND8Z     { local val:2 = *:2 IND8Z; local c:2 = zext(C_flag); subFlags16(D, val+c); D = D - val - c; setNZ16(D); }
:SBCD "#"^imm16 is op8=0x37; op8b=0xB2; imm16  { local val:2 = imm16; local c:2 = zext(C_flag); subFlags16(D, val+c); D = D - val - c; setNZ16(D); }
:SBCD IND16X    is op8=0x37; op8b=0xC2; IND16X  { local val:2 = *:2 IND16X; local c:2 = zext(C_flag); subFlags16(D, val+c); D = D - val - c; setNZ16(D); }
:SBCD IND16Y    is op8=0x37; op8b=0xD2; IND16Y  { local val:2 = *:2 IND16Y; local c:2 = zext(C_flag); subFlags16(D, val+c); D = D - val - c; setNZ16(D); }
:SBCD IND16Z    is op8=0x37; op8b=0xE2; IND16Z  { local val:2 = *:2 IND16Z; local c:2 = zext(C_flag); subFlags16(D, val+c); D = D - val - c; setNZ16(D); }
:SBCD EXT16     is op8=0x37; op8b=0xF2; EXT16   { local val:2 = *:2 EXT16;  local c:2 = zext(C_flag); subFlags16(D, val+c); D = D - val - c; setNZ16(D); }
:SBCD EOFFX     is op8=0x27; op8b=0x82; EOFFX   { local val:2 = *:2 EOFFX;  local c:2 = zext(C_flag); subFlags16(D, val+c); D = D - val - c; setNZ16(D); }
:SBCD EOFFY     is op8=0x27; op8b=0x92; EOFFY   { local val:2 = *:2 EOFFY;  local c:2 = zext(C_flag); subFlags16(D, val+c); D = D - val - c; setNZ16(D); }
:SBCD EOFFZ     is op8=0x27; op8b=0xA2; EOFFZ   { local val:2 = *:2 EOFFZ;  local c:2 = zext(C_flag); subFlags16(D, val+c); D = D - val - c; setNZ16(D); }

# = ADCD: (D) + (M:M+1) + C => D =
:ADCD IND8X     is op8=0x83; IND8X     { local val:2 = *:2 IND8X; local c:2 = zext(C_flag); addFlags16(D, val+c); D = D + val + c; setNZ16(D); }
:ADCD IND8Y     is op8=0x93; IND8Y     { local val:2 = *:2 IND8Y; local c:2 = zext(C_flag); addFlags16(D, val+c); D = D + val + c; setNZ16(D); }
:ADCD IND8Z     is op8=0xA3; IND8Z     { local val:2 = *:2 IND8Z; local c:2 = zext(C_flag); addFlags16(D, val+c); D = D + val + c; setNZ16(D); }
:ADCD "#"^imm16 is op8=0x37; op8b=0xB3; imm16  { local val:2 = imm16; local c:2 = zext(C_flag); addFlags16(D, val+c); D = D + val + c; setNZ16(D); }
:ADCD IND16X    is op8=0x37; op8b=0xC3; IND16X  { local val:2 = *:2 IND16X; local c:2 = zext(C_flag); addFlags16(D, val+c); D = D + val + c; setNZ16(D); }
:ADCD IND16Y    is op8=0x37; op8b=0xD3; IND16Y  { local val:2 = *:2 IND16Y; local c:2 = zext(C_flag); addFlags16(D, val+c); D = D + val + c; setNZ16(D); }
:ADCD IND16Z    is op8=0x37; op8b=0xE3; IND16Z  { local val:2 = *:2 IND16Z; local c:2 = zext(C_flag); addFlags16(D, val+c); D = D + val + c; setNZ16(D); }
:ADCD EXT16     is op8=0x37; op8b=0xF3; EXT16   { local val:2 = *:2 EXT16;  local c:2 = zext(C_flag); addFlags16(D, val+c); D = D + val + c; setNZ16(D); }

# = ADCD E,offset =
:ADCD EOFFX     is op8=0x27; op8b=0x83; EOFFX   { local val:2 = *:2 EOFFX;  local c:2 = zext(C_flag); addFlags16(D, val+c); D = D + val + c; setNZ16(D); }
:ADCD EOFFY     is op8=0x27; op8b=0x93; EOFFY   { local val:2 = *:2 EOFFY;  local c:2 = zext(C_flag); addFlags16(D, val+c); D = D + val + c; setNZ16(D); }
:ADCD EOFFZ     is op8=0x27; op8b=0xA3; EOFFZ   { local val:2 = *:2 EOFFZ;  local c:2 = zext(C_flag); addFlags16(D, val+c); D = D + val + c; setNZ16(D); }


# = LDD: (M:M+1) => D =
:LDD IND8X     is op8=0x85; IND8X     { D = *:2 IND8X; setNZ16(D); V_flag = 0; }
:LDD IND8Y     is op8=0x95; IND8Y     { D = *:2 IND8Y; setNZ16(D); V_flag = 0; }
:LDD IND8Z     is op8=0xA5; IND8Z     { D = *:2 IND8Z; setNZ16(D); V_flag = 0; }
:LDD "#"^imm16 is op8=0x37; op8b=0xB5; imm16  { D = imm16; setNZ16(D); V_flag = 0; }
:LDD IND16X    is op8=0x37; op8b=0xC5; IND16X  { D = *:2 IND16X; setNZ16(D); V_flag = 0; }
:LDD IND16Y    is op8=0x37; op8b=0xD5; IND16Y  { D = *:2 IND16Y; setNZ16(D); V_flag = 0; }
:LDD IND16Z    is op8=0x37; op8b=0xE5; IND16Z  { D = *:2 IND16Z; setNZ16(D); V_flag = 0; }
:LDD EXT16     is op8=0x37; op8b=0xF5; EXT16   { D = *:2 EXT16;  setNZ16(D); V_flag = 0; }
:LDD EOFFX     is op8=0x27; op8b=0x85; EOFFX   { D = *:2 EOFFX;  setNZ16(D); V_flag = 0; }
:LDD EOFFY     is op8=0x27; op8b=0x95; EOFFY   { D = *:2 EOFFY;  setNZ16(D); V_flag = 0; }
:LDD EOFFZ     is op8=0x27; op8b=0xA5; EOFFZ   { D = *:2 EOFFZ;  setNZ16(D); V_flag = 0; }

# = ANDD =
:ANDD IND8X     is op8=0x86; IND8X     { D = D & (*:2 IND8X); setNZ16(D); V_flag = 0; }
:ANDD IND8Y     is op8=0x96; IND8Y     { D = D & (*:2 IND8Y); setNZ16(D); V_flag = 0; }
:ANDD IND8Z     is op8=0xA6; IND8Z     { D = D & (*:2 IND8Z); setNZ16(D); V_flag = 0; }
:ANDD "#"^imm16 is op8=0x37; op8b=0xB6; imm16  { D = D & imm16; setNZ16(D); V_flag = 0; }
:ANDD IND16X    is op8=0x37; op8b=0xC6; IND16X  { D = D & (*:2 IND16X); setNZ16(D); V_flag = 0; }
:ANDD IND16Y    is op8=0x37; op8b=0xD6; IND16Y  { D = D & (*:2 IND16Y); setNZ16(D); V_flag = 0; }
:ANDD IND16Z    is op8=0x37; op8b=0xE6; IND16Z  { D = D & (*:2 IND16Z); setNZ16(D); V_flag = 0; }
:ANDD EXT16     is op8=0x37; op8b=0xF6; EXT16   { D = D & (*:2 EXT16);  setNZ16(D); V_flag = 0; }

# = ANDD E,offset =
:ANDD EOFFX     is op8=0x27; op8b=0x86; EOFFX   { D = D & (*:2 EOFFX);  setNZ16(D); V_flag = 0; }
:ANDD EOFFY     is op8=0x27; op8b=0x96; EOFFY   { D = D & (*:2 EOFFY);  setNZ16(D); V_flag = 0; }
:ANDD EOFFZ     is op8=0x27; op8b=0xA6; EOFFZ   { D = D & (*:2 EOFFZ);  setNZ16(D); V_flag = 0; }

# = ORD =
:ORD IND8X     is op8=0x87; IND8X     { D = D | (*:2 IND8X); setNZ16(D); V_flag = 0; }
:ORD IND8Y     is op8=0x97; IND8Y     { D = D | (*:2 IND8Y); setNZ16(D); V_flag = 0; }
:ORD IND8Z     is op8=0xA7; IND8Z     { D = D | (*:2 IND8Z); setNZ16(D); V_flag = 0; }
:ORD "#"^imm16 is op8=0x37; op8b=0xB7; imm16  { D = D | imm16; setNZ16(D); V_flag = 0; }
:ORD IND16X    is op8=0x37; op8b=0xC7; IND16X  { D = D | (*:2 IND16X); setNZ16(D); V_flag = 0; }
:ORD IND16Y    is op8=0x37; op8b=0xD7; IND16Y  { D = D | (*:2 IND16Y); setNZ16(D); V_flag = 0; }
:ORD IND16Z    is op8=0x37; op8b=0xE7; IND16Z  { D = D | (*:2 IND16Z); setNZ16(D); V_flag = 0; }
:ORD EXT16     is op8=0x37; op8b=0xF7; EXT16   { D = D | (*:2 EXT16);  setNZ16(D); V_flag = 0; }

# = ORD E,offset =
:ORD EOFFX      is op8=0x27; op8b=0x87; EOFFX   { D = D | (*:2 EOFFX);  setNZ16(D); V_flag = 0; }
:ORD EOFFY      is op8=0x27; op8b=0x97; EOFFY   { D = D | (*:2 EOFFY);  setNZ16(D); V_flag = 0; }
:ORD EOFFZ      is op8=0x27; op8b=0xA7; EOFFZ   { D = D | (*:2 EOFFZ);  setNZ16(D); V_flag = 0; }

# = CPD: (D) - (M:M+1) compare =
:CPD IND8X     is op8=0x88; IND8X     { local val:2 = *:2 IND8X; local tmp:2 = D - val; subFlags16(D, val); setNZ16(tmp); }
:CPD IND8Y     is op8=0x98; IND8Y     { local val:2 = *:2 IND8Y; local tmp:2 = D - val; subFlags16(D, val); setNZ16(tmp); }
:CPD IND8Z     is op8=0xA8; IND8Z     { local val:2 = *:2 IND8Z; local tmp:2 = D - val; subFlags16(D, val); setNZ16(tmp); }
:CPD "#"^imm16 is op8=0x37; op8b=0xB8; imm16  { local val:2 = imm16; local tmp:2 = D - val; subFlags16(D, val); setNZ16(tmp); }
:CPD IND16X    is op8=0x37; op8b=0xC8; IND16X  { local val:2 = *:2 IND16X; local tmp:2 = D - val; subFlags16(D, val); setNZ16(tmp); }
:CPD IND16Y    is op8=0x37; op8b=0xD8; IND16Y  { local val:2 = *:2 IND16Y; local tmp:2 = D - val; subFlags16(D, val); setNZ16(tmp); }
:CPD IND16Z    is op8=0x37; op8b=0xE8; IND16Z  { local val:2 = *:2 IND16Z; local tmp:2 = D - val; subFlags16(D, val); setNZ16(tmp); }
:CPD EXT16     is op8=0x37; op8b=0xF8; EXT16   { local val:2 = *:2 EXT16;  local tmp:2 = D - val; subFlags16(D, val); setNZ16(tmp); }

# = CPD E,offset =
:CPD EOFFX      is op8=0x27; op8b=0x88; EOFFX   { local val:2 = *:2 EOFFX;  local tmp:2 = D - val; subFlags16(D, val); setNZ16(tmp); }
:CPD EOFFY      is op8=0x27; op8b=0x98; EOFFY   { local val:2 = *:2 EOFFY;  local tmp:2 = D - val; subFlags16(D, val); setNZ16(tmp); }
:CPD EOFFZ      is op8=0x27; op8b=0xA8; EOFFZ   { local val:2 = *:2 EOFFZ;  local tmp:2 = D - val; subFlags16(D, val); setNZ16(tmp); }

# = EORD =
:EORD IND8X     is op8=0x84; IND8X     { D = D ^ (*:2 IND8X); setNZ16(D); V_flag = 0; }
:EORD IND8Y     is op8=0x94; IND8Y     { D = D ^ (*:2 IND8Y); setNZ16(D); V_flag = 0; }
:EORD IND8Z     is op8=0xA4; IND8Z     { D = D ^ (*:2 IND8Z); setNZ16(D); V_flag = 0; }
:EORD "#"^imm16 is op8=0x37; op8b=0xB4; imm16  { D = D ^ imm16; setNZ16(D); V_flag = 0; }
:EORD IND16X    is op8=0x37; op8b=0xC4; IND16X  { D = D ^ (*:2 IND16X); setNZ16(D); V_flag = 0; }
:EORD IND16Y    is op8=0x37; op8b=0xD4; IND16Y  { D = D ^ (*:2 IND16Y); setNZ16(D); V_flag = 0; }
:EORD IND16Z    is op8=0x37; op8b=0xE4; IND16Z  { D = D ^ (*:2 IND16Z); setNZ16(D); V_flag = 0; }
:EORD EXT16     is op8=0x37; op8b=0xF4; EXT16   { D = D ^ (*:2 EXT16);  setNZ16(D); V_flag = 0; }

# = EORD E,offset =
:EORD EOFFX     is op8=0x27; op8b=0x84; EOFFX   { D = D ^ (*:2 EOFFX);  setNZ16(D); V_flag = 0; }
:EORD EOFFY     is op8=0x27; op8b=0x94; EOFFY   { D = D ^ (*:2 EOFFY);  setNZ16(D); V_flag = 0; }
:EORD EOFFZ     is op8=0x27; op8b=0xA4; EOFFZ   { D = D ^ (*:2 EOFFZ);  setNZ16(D); V_flag = 0; }

# = STD =
:STD IND8X     is op8=0x8A; IND8X     { *:2 IND8X = D; setNZ16(D); V_flag = 0; }
:STD IND8Y     is op8=0x9A; IND8Y     { *:2 IND8Y = D; setNZ16(D); V_flag = 0; }
:STD IND8Z     is op8=0xAA; IND8Z     { *:2 IND8Z = D; setNZ16(D); V_flag = 0; }
:STD IND16X    is op8=0x37; op8b=0xCA; IND16X  { *:2 IND16X = D; setNZ16(D); V_flag = 0; }
:STD IND16Y    is op8=0x37; op8b=0xDA; IND16Y  { *:2 IND16Y = D; setNZ16(D); V_flag = 0; }
:STD IND16Z    is op8=0x37; op8b=0xEA; IND16Z  { *:2 IND16Z = D; setNZ16(D); V_flag = 0; }
:STD EXT16     is op8=0x37; op8b=0xFA; EXT16   { *:2 EXT16 = D;  setNZ16(D); V_flag = 0; }
:STD EOFFX     is op8=0x27; op8b=0x8A; EOFFX   { *:2 EOFFX = D;  setNZ16(D); V_flag = 0; }
:STD EOFFY     is op8=0x27; op8b=0x9A; EOFFY   { *:2 EOFFY = D;  setNZ16(D); V_flag = 0; }
:STD EOFFZ     is op8=0x27; op8b=0xAA; EOFFZ   { *:2 EOFFZ = D;  setNZ16(D); V_flag = 0; }


# ============================================================================
# SECTION: INDEX REGISTER / SP LOAD, STORE, COMPARE
# ============================================================================

# = LDX = (IND8X=CC, IND8Y=DC, IND8Z=EC, IMM16=37BC, IND16X=17CC, IND16Y=17DC, IND16Z=17EC, EXT=17FC)
:LDX IND8X     is op8=0xCC; IND8X     { IX = *:2 IND8X; setNZ16(IX); V_flag = 0; }
:LDX IND8Y     is op8=0xDC; IND8Y     { IX = *:2 IND8Y; setNZ16(IX); V_flag = 0; }
:LDX IND8Z     is op8=0xEC; IND8Z     { IX = *:2 IND8Z; setNZ16(IX); V_flag = 0; }
:LDX "#"^imm16 is op8=0x37; op8b=0xBC; imm16  { IX = imm16; setNZ16(IX); V_flag = 0; }
:LDX IND16X    is op8=0x17; op8b=0xCC; IND16X  { IX = *:2 IND16X; setNZ16(IX); V_flag = 0; }
:LDX IND16Y    is op8=0x17; op8b=0xDC; IND16Y  { IX = *:2 IND16Y; setNZ16(IX); V_flag = 0; }
:LDX IND16Z    is op8=0x17; op8b=0xEC; IND16Z  { IX = *:2 IND16Z; setNZ16(IX); V_flag = 0; }
:LDX EXT16     is op8=0x17; op8b=0xFC; EXT16   { IX = *:2 EXT16;  setNZ16(IX); V_flag = 0; }

# = LDY = (IND8X=CD, IND8Y=DD, IND8Z=ED, IMM16=37BD, IND16X=17CD, IND16Y=17DD, IND16Z=17ED, EXT=17FD)
:LDY IND8X     is op8=0xCD; IND8X     { IY = *:2 IND8X; setNZ16(IY); V_flag = 0; }
:LDY IND8Y     is op8=0xDD; IND8Y     { IY = *:2 IND8Y; setNZ16(IY); V_flag = 0; }
:LDY IND8Z     is op8=0xED; IND8Z     { IY = *:2 IND8Z; setNZ16(IY); V_flag = 0; }
:LDY "#"^imm16 is op8=0x37; op8b=0xBD; imm16  { IY = imm16; setNZ16(IY); V_flag = 0; }
:LDY IND16X    is op8=0x17; op8b=0xCD; IND16X  { IY = *:2 IND16X; setNZ16(IY); V_flag = 0; }
:LDY IND16Y    is op8=0x17; op8b=0xDD; IND16Y  { IY = *:2 IND16Y; setNZ16(IY); V_flag = 0; }
:LDY IND16Z    is op8=0x17; op8b=0xED; IND16Z  { IY = *:2 IND16Z; setNZ16(IY); V_flag = 0; }
:LDY EXT16     is op8=0x17; op8b=0xFD; EXT16   { IY = *:2 EXT16;  setNZ16(IY); V_flag = 0; }

# = LDZ = (IND8X=CE, IND8Y=DE, IND8Z=EE, IMM16=37BE, IND16X=17CE, IND16Y=17DE, IND16Z=17EE, EXT=17FE)
:LDZ IND8X     is op8=0xCE; IND8X     { IZ = *:2 IND8X; setNZ16(IZ); V_flag = 0; }
:LDZ IND8Y     is op8=0xDE; IND8Y     { IZ = *:2 IND8Y; setNZ16(IZ); V_flag = 0; }
:LDZ IND8Z     is op8=0xEE; IND8Z     { IZ = *:2 IND8Z; setNZ16(IZ); V_flag = 0; }
:LDZ "#"^imm16 is op8=0x37; op8b=0xBE; imm16  { IZ = imm16; setNZ16(IZ); V_flag = 0; }
:LDZ IND16X    is op8=0x17; op8b=0xCE; IND16X  { IZ = *:2 IND16X; setNZ16(IZ); V_flag = 0; }
:LDZ IND16Y    is op8=0x17; op8b=0xDE; IND16Y  { IZ = *:2 IND16Y; setNZ16(IZ); V_flag = 0; }
:LDZ IND16Z    is op8=0x17; op8b=0xEE; IND16Z  { IZ = *:2 IND16Z; setNZ16(IZ); V_flag = 0; }
:LDZ EXT16     is op8=0x17; op8b=0xFE; EXT16   { IZ = *:2 EXT16;  setNZ16(IZ); V_flag = 0; }

# = LDS = (IND8X=CF, IND8Y=DF, IND8Z=EF, IMM16=37BF, IND16X=17CF, IND16Y=17DF, IND16Z=17EF, EXT=17FF)
:LDS IND8X     is op8=0xCF; IND8X     { SP = *:2 IND8X; setNZ16(SP); V_flag = 0; }
:LDS IND8Y     is op8=0xDF; IND8Y     { SP = *:2 IND8Y; setNZ16(SP); V_flag = 0; }
:LDS IND8Z     is op8=0xEF; IND8Z     { SP = *:2 IND8Z; setNZ16(SP); V_flag = 0; }
:LDS "#"^imm16 is op8=0x37; op8b=0xBF; imm16  { SP = imm16; setNZ16(SP); V_flag = 0; }
:LDS IND16X    is op8=0x17; op8b=0xCF; IND16X  { SP = *:2 IND16X; setNZ16(SP); V_flag = 0; }
:LDS IND16Y    is op8=0x17; op8b=0xDF; IND16Y  { SP = *:2 IND16Y; setNZ16(SP); V_flag = 0; }
:LDS IND16Z    is op8=0x17; op8b=0xEF; IND16Z  { SP = *:2 IND16Z; setNZ16(SP); V_flag = 0; }
:LDS EXT16     is op8=0x17; op8b=0xFF; EXT16   { SP = *:2 EXT16;  setNZ16(SP); V_flag = 0; }

# = STX =
:STX IND8X     is op8=0x8C; IND8X     { *:2 IND8X = IX; setNZ16(IX); V_flag = 0; }
:STX IND8Y     is op8=0x9C; IND8Y     { *:2 IND8Y = IX; setNZ16(IX); V_flag = 0; }
:STX IND8Z     is op8=0xAC; IND8Z     { *:2 IND8Z = IX; setNZ16(IX); V_flag = 0; }
:STX IND16X    is op8=0x17; op8b=0x8C; IND16X  { *:2 IND16X = IX; setNZ16(IX); V_flag = 0; }
:STX IND16Y    is op8=0x17; op8b=0x9C; IND16Y  { *:2 IND16Y = IX; setNZ16(IX); V_flag = 0; }
:STX IND16Z    is op8=0x17; op8b=0xAC; IND16Z  { *:2 IND16Z = IX; setNZ16(IX); V_flag = 0; }
:STX EXT16     is op8=0x17; op8b=0xBC; EXT16   { *:2 EXT16 = IX;  setNZ16(IX); V_flag = 0; }

# = STY =
:STY IND8X     is op8=0x8D; IND8X     { *:2 IND8X = IY; setNZ16(IY); V_flag = 0; }
:STY IND8Y     is op8=0x9D; IND8Y     { *:2 IND8Y = IY; setNZ16(IY); V_flag = 0; }
:STY IND8Z     is op8=0xAD; IND8Z     { *:2 IND8Z = IY; setNZ16(IY); V_flag = 0; }
:STY IND16X    is op8=0x17; op8b=0x8D; IND16X  { *:2 IND16X = IY; setNZ16(IY); V_flag = 0; }
:STY IND16Y    is op8=0x17; op8b=0x9D; IND16Y  { *:2 IND16Y = IY; setNZ16(IY); V_flag = 0; }
:STY IND16Z    is op8=0x17; op8b=0xAD; IND16Z  { *:2 IND16Z = IY; setNZ16(IY); V_flag = 0; }
:STY EXT16     is op8=0x17; op8b=0xBD; EXT16   { *:2 EXT16 = IY;  setNZ16(IY); V_flag = 0; }

# = STZ =
:STZ IND8X     is op8=0x8E; IND8X     { *:2 IND8X = IZ; setNZ16(IZ); V_flag = 0; }
:STZ IND8Y     is op8=0x9E; IND8Y     { *:2 IND8Y = IZ; setNZ16(IZ); V_flag = 0; }
:STZ IND8Z     is op8=0xAE; IND8Z     { *:2 IND8Z = IZ; setNZ16(IZ); V_flag = 0; }
:STZ IND16X    is op8=0x17; op8b=0x8E; IND16X  { *:2 IND16X = IZ; setNZ16(IZ); V_flag = 0; }
:STZ IND16Y    is op8=0x17; op8b=0x9E; IND16Y  { *:2 IND16Y = IZ; setNZ16(IZ); V_flag = 0; }
:STZ IND16Z    is op8=0x17; op8b=0xAE; IND16Z  { *:2 IND16Z = IZ; setNZ16(IZ); V_flag = 0; }
:STZ EXT16     is op8=0x17; op8b=0xBE; EXT16   { *:2 EXT16 = IZ;  setNZ16(IZ); V_flag = 0; }

# = STS =
:STS IND8X     is op8=0x8F; IND8X     { *:2 IND8X = SP; setNZ16(SP); V_flag = 0; }
:STS IND8Y     is op8=0x9F; IND8Y     { *:2 IND8Y = SP; setNZ16(SP); V_flag = 0; }
:STS IND8Z     is op8=0xAF; IND8Z     { *:2 IND8Z = SP; setNZ16(SP); V_flag = 0; }
:STS IND16X    is op8=0x17; op8b=0x8F; IND16X  { *:2 IND16X = SP; setNZ16(SP); V_flag = 0; }
:STS IND16Y    is op8=0x17; op8b=0x9F; IND16Y  { *:2 IND16Y = SP; setNZ16(SP); V_flag = 0; }
:STS IND16Z    is op8=0x17; op8b=0xAF; IND16Z  { *:2 IND16Z = SP; setNZ16(SP); V_flag = 0; }
:STS EXT16     is op8=0x17; op8b=0xBF; EXT16   { *:2 EXT16 = SP;  setNZ16(SP); V_flag = 0; }


# ============================================================================
# SECTION: BRANCH INSTRUCTIONS
# ============================================================================

# = Short Branches (REL8) =
# Use REL8ADDR sub-constructor which computes target at disassembly time.
:BRA  REL8ADDR   is op8=0xB0; REL8ADDR  { goto REL8ADDR; }
:BRN  REL8ADDR   is op8=0xB1; REL8ADDR  { }
:BHI  REL8ADDR   is op8=0xB2; REL8ADDR  { if ((C_flag | Z_flag) == 0) goto REL8ADDR; }
:BLS  REL8ADDR   is op8=0xB3; REL8ADDR  { if ((C_flag | Z_flag) != 0) goto REL8ADDR; }
:BCC  REL8ADDR   is op8=0xB4; REL8ADDR  { if (C_flag == 0) goto REL8ADDR; }
:BCS  REL8ADDR   is op8=0xB5; REL8ADDR  { if (C_flag != 0) goto REL8ADDR; }
:BNE  REL8ADDR   is op8=0xB6; REL8ADDR  { if (Z_flag == 0) goto REL8ADDR; }
:BEQ  REL8ADDR   is op8=0xB7; REL8ADDR  { if (Z_flag != 0) goto REL8ADDR; }
:BVC  REL8ADDR   is op8=0xB8; REL8ADDR  { if (V_flag == 0) goto REL8ADDR; }
:BVS  REL8ADDR   is op8=0xB9; REL8ADDR  { if (V_flag != 0) goto REL8ADDR; }
:BPL  REL8ADDR   is op8=0xBA; REL8ADDR  { if (N_flag == 0) goto REL8ADDR; }
:BMI  REL8ADDR   is op8=0xBB; REL8ADDR  { if (N_flag != 0) goto REL8ADDR; }
:BGE  REL8ADDR   is op8=0xBC; REL8ADDR  { if ((N_flag ^ V_flag) == 0) goto REL8ADDR; }
:BLT  REL8ADDR   is op8=0xBD; REL8ADDR  { if ((N_flag ^ V_flag) != 0) goto REL8ADDR; }
:BGT  REL8ADDR   is op8=0xBE; REL8ADDR  { if ((Z_flag | (N_flag ^ V_flag)) == 0) goto REL8ADDR; }
:BLE  REL8ADDR   is op8=0xBF; REL8ADDR  { if ((Z_flag | (N_flag ^ V_flag)) != 0) goto REL8ADDR; }

# = BSR (Branch to Subroutine) =
:BSR  REL8ADDR   is op8=0x36; REL8ADDR {
    SSP = SSP - 4;
    call REL8ADDR;
}

# = Long Branches (REL16) - Page 4 prefix 0x37 =
:LBRA  REL16ADDR   is op8=0x37; op8b=0x80; REL16ADDR  { goto REL16ADDR; }
:LBRN  REL16ADDR   is op8=0x37; op8b=0x81; REL16ADDR  { }
:LBHI  REL16ADDR   is op8=0x37; op8b=0x82; REL16ADDR  { if ((C_flag | Z_flag) == 0) goto REL16ADDR; }
:LBLS  REL16ADDR   is op8=0x37; op8b=0x83; REL16ADDR  { if ((C_flag | Z_flag) != 0) goto REL16ADDR; }
:LBCC  REL16ADDR   is op8=0x37; op8b=0x84; REL16ADDR  { if (C_flag == 0) goto REL16ADDR; }
:LBCS  REL16ADDR   is op8=0x37; op8b=0x85; REL16ADDR  { if (C_flag != 0) goto REL16ADDR; }
:LBNE  REL16ADDR   is op8=0x37; op8b=0x86; REL16ADDR  { if (Z_flag == 0) goto REL16ADDR; }
:LBEQ  REL16ADDR   is op8=0x37; op8b=0x87; REL16ADDR  { if (Z_flag != 0) goto REL16ADDR; }
:LBVC  REL16ADDR   is op8=0x37; op8b=0x88; REL16ADDR  { if (V_flag == 0) goto REL16ADDR; }
:LBVS  REL16ADDR   is op8=0x37; op8b=0x89; REL16ADDR  { if (V_flag != 0) goto REL16ADDR; }
:LBPL  REL16ADDR   is op8=0x37; op8b=0x8A; REL16ADDR  { if (N_flag == 0) goto REL16ADDR; }
:LBMI  REL16ADDR   is op8=0x37; op8b=0x8B; REL16ADDR  { if (N_flag != 0) goto REL16ADDR; }
:LBGE  REL16ADDR   is op8=0x37; op8b=0x8C; REL16ADDR  { if ((N_flag ^ V_flag) == 0) goto REL16ADDR; }
:LBLT  REL16ADDR   is op8=0x37; op8b=0x8D; REL16ADDR  { if ((N_flag ^ V_flag) != 0) goto REL16ADDR; }
:LBGT  REL16ADDR   is op8=0x37; op8b=0x8E; REL16ADDR  { if ((Z_flag | (N_flag ^ V_flag)) == 0) goto REL16ADDR; }
:LBLE  REL16ADDR   is op8=0x37; op8b=0x8F; REL16ADDR  { if ((Z_flag | (N_flag ^ V_flag)) != 0) goto REL16ADDR; }

# = LBEV / LBMV (DSP long branches) =
:LBMV  REL16ADDR   is op8=0x37; op8b=0x90; REL16ADDR  { if (MV_flag != 0) goto REL16ADDR; }
:LBEV  REL16ADDR   is op8=0x37; op8b=0x91; REL16ADDR  { if (EV_flag != 0) goto REL16ADDR; }

# = LBSR (Long Branch to Subroutine) =
:LBSR  REL16ADDR   is op8=0x27; op8b=0xF9; REL16ADDR {
    SSP = SSP - 4;
    call REL16ADDR;
}


# ============================================================================
# SECTION: JUMP, SUBROUTINE CALL, RETURN
# ============================================================================

# = JMP (Extended 20-bit and Indexed 20-bit) =
:JMP EXT20ADDR       is op8=0x7A; EXT20ADDR           { goto EXT20ADDR; }
:JMP IND20X          is op8=0x4B; IND20X               { goto [IND20X]; }
:JMP IND20Y          is op8=0x5B; IND20Y               { goto [IND20Y]; }
:JMP IND20Z          is op8=0x6B; IND20Z               { goto [IND20Z]; }

# = JSR (Jump to Subroutine - Extended 20 and Indexed 20) =
:JSR EXT20ADDR       is op8=0xFA; EXT20ADDR {
    SSP = SSP - 4;
    call EXT20ADDR;
}
:JSR IND20X          is op8=0x89; IND20X {
    SSP = SSP - 4;
    call [IND20X];
}
:JSR IND20Y          is op8=0x99; IND20Y {
    SSP = SSP - 4;
    call [IND20Y];
}
:JSR IND20Z          is op8=0xA9; IND20Z {
    SSP = SSP - 4;
    call [IND20Z];
}

# = RTS (Return from Subroutine) =
:RTS   is op8=0x27; op8b=0xF7 {
    SSP = SSP + 4;
    return [PC];
}



# = RTI (Return from Interrupt) =
:RTI   is op8=0x27; op8b=0x77 {
    pull16(CCR);
    syncPullPK(CCR);
    local retaddr:2;
    pull16(retaddr);
    local fulladdr:3 = (zext(PK:1) << 16) | zext(retaddr);
    return [fulladdr];
}

# = SWI (Software Interrupt) =
:SWI   is op8=0x37; op8b=0x20 {
    SSP = SSP - 4;
    local vec:3 = 0x000C;
    local target:2 = *:2 vec;
    call [target];
}


# ============================================================================
# SECTION: INHERENT (REGISTER) INSTRUCTIONS - Page 4 (37xx)
# ============================================================================

# = Inter-accumulator operations =
:ABA   is op8=0x37; op8b=0x0B  { addFlags(A, B); A = A + B; setNZ8(A); }
:SBA   is op8=0x37; op8b=0x0A  { subFlags(A, B); A = A - B; setNZ8(A); }
:CBA   is op8=0x37; op8b=0x1B  { local tmp:1 = A - B; subFlags(A, B); setNZ8(tmp); }

# = Transfer and Exchange =
:TAB   is op8=0x37; op8b=0x17  { B = A; setNZ8(B); V_flag = 0; }
:TBA   is op8=0x37; op8b=0x07  { A = B; setNZ8(A); V_flag = 0; }
:XGAB  is op8=0x37; op8b=0x1A  { local tmp:1 = A; A = B; B = tmp; }
:XGDE  is op8=0x27; op8b=0x7A  { local tmp:2 = D; D = E; E = tmp; }
:XGDX  is op8=0x37; op8b=0xCC  { local tmp:2 = D; D = IX; IX = tmp; }
:XGDY  is op8=0x37; op8b=0xDC  { local tmp:2 = D; D = IY; IY = tmp; }
:XGDZ  is op8=0x37; op8b=0xEC  { local tmp:2 = D; D = IZ; IZ = tmp; }
:XGEX  is op8=0x37; op8b=0x4C  { local tmp:2 = E; E = IX; IX = tmp; }
:XGEY  is op8=0x37; op8b=0x5C  { local tmp:2 = E; E = IY; IY = tmp; }
:XGEZ  is op8=0x37; op8b=0x6C  { local tmp:2 = E; E = IZ; IZ = tmp; }

# = TDE/TED/TDP/TPD etc. =
:TDE   is op8=0x27; op8b=0x7B  { E = D; }
:TED   is op8=0x27; op8b=0xFB  { D = E; }

# = Transfer Index to SP (with -2) =
:TXS   is op8=0x37; op8b=0x4E  {
    local tmp:3 = (zext(XK:1) << 16) | zext(IX:2);
    tmp = tmp - 2;
    SK = tmp[16,4];
    SP = tmp:2;
}
:TYS   is op8=0x37; op8b=0x5E  {
    local tmp:3 = (zext(YK:1) << 16) | zext(IY:2);
    tmp = tmp - 2;
    SK = tmp[16,4];
    SP = tmp:2;
}
:TZS   is op8=0x37; op8b=0x6E  {
    local tmp:3 = (zext(ZK:1) << 16) | zext(IZ:2);
    tmp = tmp - 2;
    SK = tmp[16,4];
    SP = tmp:2;
}
# = Transfer SP to Index (with +2) =
:TSX   is op8=0x27; op8b=0x4F  {
    local tmp:3 = SSP + 2;
    XK = tmp[16,4];
    IX = tmp:2;
}
:TSY   is op8=0x27; op8b=0x5F  {
    local tmp:3 = (zext(SK:1) << 16) | zext(SP:2);
    tmp = tmp + 2;
    YK = tmp[16,4];
    IY = tmp:2;
}
:TSZ   is op8=0x27; op8b=0x6F  {
    local tmp:3 = SSP + 2;
    ZK = tmp[16,4];
    IZ = tmp:2;
}

# = Inter-index-register transfers =
:TXY   is op8=0x27; op8b=0x5C  { YK = XK; IY = IX; }
:TXZ   is op8=0x27; op8b=0x6C  { ZK = XK; IZ = IX; }
:TYX   is op8=0x27; op8b=0x4D  { XK = YK; IX = IY; }
:TYZ   is op8=0x27; op8b=0x6D  { ZK = YK; IZ = IY; }
:TZX   is op8=0x27; op8b=0x4E  { XK = ZK; IX = IZ; }
:TZY   is op8=0x27; op8b=0x5E  { YK = ZK; IY = IZ; }

# = SXT: Sign Extend B into A =
:SXT   is op8=0x27; op8b=0xF8  { A = (B s>> 7); setNZ8(A); }

# = Extension register transfers (B <-> xK) =
:TBEK  is op8=0x27; op8b=0xFA  { EK = B & 0x0F; }
:TBXK  is op8=0x37; op8b=0x9C  { XK = B & 0x0F; }
:TBYK  is op8=0x37; op8b=0x9D  { YK = B & 0x0F; }
:TBZK  is op8=0x37; op8b=0x9E  { ZK = B & 0x0F; }
:TBSK  is op8=0x37; op8b=0x9F  { SK = B & 0x0F; }
:TEKB  is op8=0x27; op8b=0xBB  { B = EK & 0x0F; }
:TXKB  is op8=0x37; op8b=0xAC  { B = XK & 0x0F; }
:TYKB  is op8=0x37; op8b=0xAD  { B = YK & 0x0F; }
:TZKB  is op8=0x37; op8b=0xAE  { B = ZK & 0x0F; }
:TSKB  is op8=0x37; op8b=0xAF  { B = SK & 0x0F; }

# = CCR register transfers =
:TPA   is op8=0x37; op8b=0xFC  { A = CCR[8,8]; }
:TAP   is op8=0x37; op8b=0xFD  { CCR = (CCR & 0x00FF) | (zext(A:1) << 8); }
:TPD   is op8=0x37; op8b=0x2C  { D = (CCR & 0xFFF0) | zext(PK & 0x0F); }
:TDP   is op8=0x37; op8b=0x2D  { CCR = (CCR & 0x000F) | (D & 0xFFF0); }

# = Add B to Index Register =
:ABX   is op8=0x37; op8b=0x4F  { local ext:3 = (zext(XK:1) << 16) | zext(IX:2); ext = ext + zext(B:1); XK = ext[16,4]; IX = ext:2; }
:ABY   is op8=0x37; op8b=0x5F  { local ext:3 = (zext(YK:1) << 16) | zext(IY:2); ext = ext + zext(B:1); YK = ext[16,4]; IY = ext:2; }
:ABZ   is op8=0x37; op8b=0x6F  { local ext:3 = (zext(ZK:1) << 16) | zext(IZ:2); ext = ext + zext(B:1); ZK = ext[16,4]; IZ = ext:2; }

# = ADE/SDE =
:ADE   is op8=0x27; op8b=0x78  { addFlags16(E, D); E = E + D; setNZ16(E); }
:SDE   is op8=0x27; op8b=0x79  { subFlags16(E, D); E = E - D; setNZ16(E); }

# = Add D/E to Index Registers =
:ADX   is op8=0x37; op8b=0xCD  { IX = IX + D; }
:ADY   is op8=0x37; op8b=0xDD  { IY = IY + D; }
:ADZ   is op8=0x37; op8b=0xED  { IZ = IZ + D; }
:AEX   is op8=0x37; op8b=0x4D  { IX = IX + E; }
:AEY   is op8=0x37; op8b=0x5D  { IY = IY + E; }
:AEZ   is op8=0x37; op8b=0x6D  { IZ = IZ + E; }

# = Add Immediate to Index / Stack =
:AIX "#"^simm8   is op8=0x3C; simm8    { IX = IX + sext(simm8:1); Z_flag = (IX == 0); }
:AIY "#"^simm8   is op8=0x3D; simm8    { IY = IY + sext(simm8:1); Z_flag = (IY == 0); }
:AIZ "#"^simm8   is op8=0x3E; simm8    { IZ = IZ + sext(simm8:1); Z_flag = (IZ == 0); }
:AIS "#"^simm8   is op8=0x3F; simm8    { SSP = SSP + sext(simm8:1); }
:AIX "#"^simm16  is op8=0x37; op8b=0x3C; simm16  { IX = IX + simm16; Z_flag = (IX == 0); }
:AIY "#"^simm16  is op8=0x37; op8b=0x3D; simm16  { IY = IY + simm16; Z_flag = (IY == 0); }
:AIZ "#"^simm16  is op8=0x37; op8b=0x3E; simm16  { IZ = IZ + simm16; Z_flag = (IZ == 0); }
:AIS "#"^simm16  is op8=0x37; op8b=0x3F; simm16  { SSP = SSP + simm16; }

# = Register Clear, Complement, Negate (Inherent) =
:CLRA   is op8=0x37; op8b=0x05  { A = 0; N_flag = 0; Z_flag = 1; V_flag = 0; C_flag = 0; }
:CLRB   is op8=0x37; op8b=0x15  { B = 0; N_flag = 0; Z_flag = 1; V_flag = 0; C_flag = 0; }
:CLRD   is op8=0x27; op8b=0xF5  { D = 0; N_flag = 0; Z_flag = 1; V_flag = 0; C_flag = 0; }
:CLRE   is op8=0x27; op8b=0x75  { E = 0; N_flag = 0; Z_flag = 1; V_flag = 0; C_flag = 0; }

:COMA   is op8=0x37; op8b=0x00  { A = ~A; setNZ8(A); V_flag = 0; C_flag = 1; }
:COMB   is op8=0x37; op8b=0x10  { B = ~B; setNZ8(B); V_flag = 0; C_flag = 1; }
:COMD   is op8=0x27; op8b=0xF0  { D = ~D; setNZ16(D); V_flag = 0; C_flag = 1; }
:COME   is op8=0x27; op8b=0x70  { E = ~E; setNZ16(E); V_flag = 0; C_flag = 1; }

:NEGA   is op8=0x37; op8b=0x02  { V_flag = (A == 0x80); C_flag = (A != 0); A = -A; setNZ8(A); }
:NEGB   is op8=0x37; op8b=0x12  { V_flag = (B == 0x80); C_flag = (B != 0); B = -B; setNZ8(B); }
:NEGD   is op8=0x27; op8b=0xF2  { V_flag = (D == 0x8000); C_flag = (D != 0); D = -D; setNZ16(D); }
:NEGE   is op8=0x27; op8b=0x72  { V_flag = (E == 0x8000); C_flag = (E != 0); E = -E; setNZ16(E); }

:DECA   is op8=0x37; op8b=0x01  { V_flag = (A == 0x80); A = A - 1; setNZ8(A); }
:DECB   is op8=0x37; op8b=0x11  { V_flag = (B == 0x80); B = B - 1; setNZ8(B); }

:INCA   is op8=0x37; op8b=0x03  { V_flag = (A == 0x7F); A = A + 1; setNZ8(A); }
:INCB   is op8=0x37; op8b=0x13  { V_flag = (B == 0x7F); B = B + 1; setNZ8(B); }

:TSTA   is op8=0x37; op8b=0x06  { setNZ8(A); V_flag = 0; C_flag = 0; }
:TSTB   is op8=0x37; op8b=0x16  { setNZ8(B); V_flag = 0; C_flag = 0; }
:TSTD   is op8=0x27; op8b=0xF6  { setNZ16(D); V_flag = 0; C_flag = 0; }
:TSTE   is op8=0x27; op8b=0x76  { setNZ16(E); V_flag = 0; C_flag = 0; }

# = Shift/Rotate (Inherent) =
:ASLA   is op8=0x37; op8b=0x04  { C_flag = A[7,1]; V_flag = A[7,1] ^ A[6,1]; A = A << 1; setNZ8(A); }
:ASLB   is op8=0x37; op8b=0x14  { C_flag = B[7,1]; V_flag = B[7,1] ^ B[6,1]; B = B << 1; setNZ8(B); }
:ASLD   is op8=0x27; op8b=0xF4  { C_flag = D[15,1]; V_flag = D[15,1] ^ D[14,1]; D = D << 1; setNZ16(D); }
:ASLE   is op8=0x27; op8b=0x74  { C_flag = E[15,1]; V_flag = E[15,1] ^ E[14,1]; E = E << 1; setNZ16(E); }

:ASRA   is op8=0x37; op8b=0x0D  { C_flag = A[0,1]; V_flag = A[7,1] ^ A[0,1]; A = A s>> 1; setNZ8(A); }
:ASRB   is op8=0x37; op8b=0x1D  { C_flag = B[0,1]; V_flag = B[7,1] ^ B[0,1]; B = B s>> 1; setNZ8(B); }
:LSRA   is op8=0x37; op8b=0x0F  { C_flag = A[0,1]; A = A >> 1; N_flag = 0; Z_flag = (A == 0); V_flag = C_flag; }
:LSRB   is op8=0x37; op8b=0x1F  { C_flag = B[0,1]; B = B >> 1; N_flag = 0; Z_flag = (B == 0); V_flag = C_flag; }
:ASRD   is op8=0x27; op8b=0xFD  { C_flag = D[0,1]; V_flag = D[15,1] ^ D[0,1]; D = D s>> 1; setNZ16(D); }
:ASRE   is op8=0x27; op8b=0x7D  { C_flag = E[0,1]; V_flag = E[15,1] ^ E[0,1]; E = E s>> 1; setNZ16(E); }

:LSRD   is op8=0x27; op8b=0xFF  { C_flag = D[0,1]; D = D >> 1; setNZ16(D); V_flag = N_flag ^ C_flag; }
:LSRE   is op8=0x27; op8b=0x7F  { C_flag = E[0,1]; E = E >> 1; setNZ16(E); V_flag = N_flag ^ C_flag; }

:ROLA   is op8=0x37; op8b=0x0C  { local c:1 = C_flag; C_flag = A[7,1]; V_flag = A[7,1] ^ A[6,1]; A = (A << 1) | c; setNZ8(A); }
:ROLB   is op8=0x37; op8b=0x1C  { local c:1 = C_flag; C_flag = B[7,1]; V_flag = B[7,1] ^ B[6,1]; B = (B << 1) | c; setNZ8(B); }

:RORA   is op8=0x37; op8b=0x0E  { local c:1 = C_flag; C_flag = A[0,1]; V_flag = A[7,1] ^ C_flag; A = (A >> 1) | (c << 7); setNZ8(A); }
:RORB   is op8=0x37; op8b=0x1E  { local c:1 = C_flag; C_flag = B[0,1]; V_flag = B[7,1] ^ C_flag; B = (B >> 1) | (c << 7); setNZ8(B); }

# = MUL: (A) * (B) => D =
:MUL    is op8=0x37; op8b=0x24  { D = zext(A:1) * zext(B:1); C_flag = D[7,1]; }

# = EMUL / EMULS: Unsigned/Signed 16x16 => 32 multiply =
:EMUL   is op8=0x37; op8b=0x25  { local res:4 = zext(E:2) * zext(D:2); E = res[16,16]; D = res[0,16]; C_flag = D[15,1]; setNZ16(D); }
:EMULS  is op8=0x37; op8b=0x26  { local res:4 = sext(E:2) * sext(D:2); E = res[16,16]; D = res[0,16]; setNZ16(D); }

# = EDIV / EDIVS =
:EDIV   is op8=0x37; op8b=0x28  {
    local dividend:4 = (zext(E:2) << 16) | zext(D:2);
    local divisor:4 = zext(IX:2);
    if (divisor == 0) goto <divzero>;
    local quot:4 = dividend / divisor;
    local rem:4 = dividend % divisor;
    IX = quot:2;
    D = rem:2;
    setNZ16(IX);
    V_flag = (quot > 0xFFFF);
    C_flag = 0;
    goto <done>;
    <divzero>
    C_flag = 1;
    <done>
}

# = EDIVS =
:EDIVS  is op8=0x37; op8b=0x29  {
    local dividend:4 = (zext(E:2) << 16) | zext(D:2);
    local divisor:4 = sext(IX:2);
    if (divisor == 0) goto <divzero>;
    local quot:4 = dividend s/ divisor;
    local rem:4 = dividend - (quot * divisor);
    IX = quot:2;
    D = rem:2;
    setNZ16(IX);
    V_flag = (quot s> 0x7FFF) | (quot s< -32768);
    C_flag = 0;
    goto <done>;
    <divzero>
    C_flag = 1;
    <done>
}

# = IDIV =
:IDIV   is op8=0x37; op8b=0x2A  {
    C_flag = (IX == 0);
    V_flag = 0;
    if (IX == 0) goto <divzero>;
    local dividend:2 = D;
    local divisor:2 = IX;
    IX = dividend / divisor;
    D = dividend % divisor;
    Z_flag = (IX == 0);
    goto <done>;
    <divzero>
    IX = 0xFFFF;
    <done>
}

# = FDIV =
:FDIV   is op8=0x37; op8b=0x2B  {
    local dividend:4 = zext(D:2) << 16;
    local divisor:4 = zext(IX:2);
    if (divisor == 0) goto <divzero>;
    local quot:4 = dividend / divisor;
    local rem:4 = dividend % divisor;
    IX = quot:2;
    D = rem:2;
    V_flag = (D >= IX);
    C_flag = 0;
    goto <done>;
    <divzero>
    C_flag = 1;
    <done>
}

# = DAA =
:DAA   is op8=0x37; op8b=0x21  {
    # Decimal Adjust Accumulator A (placeholder - complex BCD logic)
    local tmp:2 = zext(A:1);
    if ((A & 0x0F) > 9 || H_flag != 0) goto <lower>;
    goto <chkupper>;
    <lower>
    tmp = tmp + 6;
    <chkupper>
    if (((tmp >> 4) & 0x0F) > 9 || C_flag != 0) goto <upper>;
    goto <done>;
    <upper>
    tmp = tmp + 0x60;
    C_flag = 1;
    <done>
    A = tmp:1;
    setNZ8(A);
}

# = NOP =
:NOP    is op8=0x27; op8b=0x4C  { }

# = BGND =
:BGND   is op8=0x37; op8b=0xA6  { }

# = ANDP / ORP (CCR manipulation) =
:ANDP "#"^imm16  is op8=0x37; op8b=0x3A; imm16  {
    local pk_save:2 = CCR & 0x000F;
    CCR = (CCR & imm16 & 0xFFF0) | pk_save;
}
:ORP  "#"^imm16  is op8=0x37; op8b=0x3B; imm16  {
    local pk_save:2 = CCR & 0x000F;
    CCR = ((CCR | imm16) & 0xFFF0) | pk_save;
}


# ============================================================================
# SECTION: MEMORY BYTE OPERATIONS (CLR, COM, NEG, INC, DEC, TST, ASL, ASR, LSR, ROL, ROR)
# Page 1: 0x=IND8,X  1x=IND8,Y  2x=IND8,Z
# Page 2: 170x=IND16,X  171x=IND16,Y  172x=IND16,Z  173x=EXT
# ============================================================================

# = COM: ~(M) => M =
:COM IND8X     is op8=0x00; IND8X     { local val:1 = *:1 IND8X; val = ~val; *:1 IND8X = val; setNZ8(val); V_flag = 0; C_flag = 1; }
:COM IND8Y     is op8=0x10; IND8Y     { local val:1 = *:1 IND8Y; val = ~val; *:1 IND8Y = val; setNZ8(val); V_flag = 0; C_flag = 1; }
:COM IND8Z     is op8=0x20; IND8Z     { local val:1 = *:1 IND8Z; val = ~val; *:1 IND8Z = val; setNZ8(val); V_flag = 0; C_flag = 1; }
:COM IND16X    is op8=0x17; op8b=0x00; IND16X  { local val:1 = *:1 IND16X; val = ~val; *:1 IND16X = val; setNZ8(val); V_flag = 0; C_flag = 1; }
:COM IND16Y    is op8=0x17; op8b=0x10; IND16Y  { local val:1 = *:1 IND16Y; val = ~val; *:1 IND16Y = val; setNZ8(val); V_flag = 0; C_flag = 1; }
:COM IND16Z    is op8=0x17; op8b=0x20; IND16Z  { local val:1 = *:1 IND16Z; val = ~val; *:1 IND16Z = val; setNZ8(val); V_flag = 0; C_flag = 1; }
:COM EXT16     is op8=0x17; op8b=0x30; EXT16   { local val:1 = *:1 EXT16;  val = ~val; *:1 EXT16 = val;  setNZ8(val); V_flag = 0; C_flag = 1; }

# = DEC: (M) - 1 => M =
:DEC IND8X     is op8=0x01; IND8X     { local val:1 = *:1 IND8X; V_flag = (val == 0x80); val = val - 1; *:1 IND8X = val; setNZ8(val); }
:DEC IND8Y     is op8=0x11; IND8Y     { local val:1 = *:1 IND8Y; V_flag = (val == 0x80); val = val - 1; *:1 IND8Y = val; setNZ8(val); }
:DEC IND8Z     is op8=0x21; IND8Z     { local val:1 = *:1 IND8Z; V_flag = (val == 0x80); val = val - 1; *:1 IND8Z = val; setNZ8(val); }
:DEC IND16X    is op8=0x17; op8b=0x01; IND16X  { local val:1 = *:1 IND16X; V_flag = (val == 0x80); val = val - 1; *:1 IND16X = val; setNZ8(val); }
:DEC IND16Y    is op8=0x17; op8b=0x11; IND16Y  { local val:1 = *:1 IND16Y; V_flag = (val == 0x80); val = val - 1; *:1 IND16Y = val; setNZ8(val); }
:DEC IND16Z    is op8=0x17; op8b=0x21; IND16Z  { local val:1 = *:1 IND16Z; V_flag = (val == 0x80); val = val - 1; *:1 IND16Z = val; setNZ8(val); }
:DEC EXT16     is op8=0x17; op8b=0x31; EXT16   { local val:1 = *:1 EXT16;  V_flag = (val == 0x80); val = val - 1; *:1 EXT16 = val;  setNZ8(val); }

# = NEG: 0 - (M) => M =
:NEG IND8X     is op8=0x02; IND8X     { local val:1 = *:1 IND8X; V_flag = (val == 0x80); C_flag = (val != 0); val = -val; *:1 IND8X = val; setNZ8(val); }
:NEG IND8Y     is op8=0x12; IND8Y     { local val:1 = *:1 IND8Y; V_flag = (val == 0x80); C_flag = (val != 0); val = -val; *:1 IND8Y = val; setNZ8(val); }
:NEG IND8Z     is op8=0x22; IND8Z     { local val:1 = *:1 IND8Z; V_flag = (val == 0x80); C_flag = (val != 0); val = -val; *:1 IND8Z = val; setNZ8(val); }
:NEG IND16X    is op8=0x17; op8b=0x02; IND16X  { local val:1 = *:1 IND16X; V_flag = (val == 0x80); C_flag = (val != 0); val = -val; *:1 IND16X = val; setNZ8(val); }
:NEG IND16Y    is op8=0x17; op8b=0x12; IND16Y  { local val:1 = *:1 IND16Y; V_flag = (val == 0x80); C_flag = (val != 0); val = -val; *:1 IND16Y = val; setNZ8(val); }
:NEG IND16Z    is op8=0x17; op8b=0x22; IND16Z  { local val:1 = *:1 IND16Z; V_flag = (val == 0x80); C_flag = (val != 0); val = -val; *:1 IND16Z = val; setNZ8(val); }
:NEG EXT16     is op8=0x17; op8b=0x32; EXT16   { local val:1 = *:1 EXT16;  V_flag = (val == 0x80); C_flag = (val != 0); val = -val; *:1 EXT16 = val;  setNZ8(val); }

# = INC: (M) + 1 => M =
:INC IND8X     is op8=0x03; IND8X     { local val:1 = *:1 IND8X; V_flag = (val == 0x7F); val = val + 1; *:1 IND8X = val; setNZ8(val); }
:INC IND8Y     is op8=0x13; IND8Y     { local val:1 = *:1 IND8Y; V_flag = (val == 0x7F); val = val + 1; *:1 IND8Y = val; setNZ8(val); }
:INC IND8Z     is op8=0x23; IND8Z     { local val:1 = *:1 IND8Z; V_flag = (val == 0x7F); val = val + 1; *:1 IND8Z = val; setNZ8(val); }
:INC IND16X    is op8=0x17; op8b=0x03; IND16X  { local val:1 = *:1 IND16X; V_flag = (val == 0x7F); val = val + 1; *:1 IND16X = val; setNZ8(val); }
:INC IND16Y    is op8=0x17; op8b=0x13; IND16Y  { local val:1 = *:1 IND16Y; V_flag = (val == 0x7F); val = val + 1; *:1 IND16Y = val; setNZ8(val); }
:INC IND16Z    is op8=0x17; op8b=0x23; IND16Z  { local val:1 = *:1 IND16Z; V_flag = (val == 0x7F); val = val + 1; *:1 IND16Z = val; setNZ8(val); }
:INC EXT16     is op8=0x17; op8b=0x33; EXT16   { local val:1 = *:1 EXT16;  V_flag = (val == 0x7F); val = val + 1; *:1 EXT16 = val;  setNZ8(val); }

# = ASL (memory byte) =
:ASL IND8X     is op8=0x04; IND8X     { local val:1 = *:1 IND8X; C_flag = val[7,1]; V_flag = val[7,1] ^ val[6,1]; val = val << 1; *:1 IND8X = val; setNZ8(val); }
:ASL IND8Y     is op8=0x14; IND8Y     { local val:1 = *:1 IND8Y; C_flag = val[7,1]; V_flag = val[7,1] ^ val[6,1]; val = val << 1; *:1 IND8Y = val; setNZ8(val); }
:ASL IND8Z     is op8=0x24; IND8Z     { local val:1 = *:1 IND8Z; C_flag = val[7,1]; V_flag = val[7,1] ^ val[6,1]; val = val << 1; *:1 IND8Z = val; setNZ8(val); }
:ASL IND16X    is op8=0x17; op8b=0x04; IND16X  { local val:1 = *:1 IND16X; C_flag = val[7,1]; V_flag = val[7,1] ^ val[6,1]; val = val << 1; *:1 IND16X = val; setNZ8(val); }
:ASL IND16Y    is op8=0x17; op8b=0x14; IND16Y  { local val:1 = *:1 IND16Y; C_flag = val[7,1]; V_flag = val[7,1] ^ val[6,1]; val = val << 1; *:1 IND16Y = val; setNZ8(val); }
:ASL IND16Z    is op8=0x17; op8b=0x24; IND16Z  { local val:1 = *:1 IND16Z; C_flag = val[7,1]; V_flag = val[7,1] ^ val[6,1]; val = val << 1; *:1 IND16Z = val; setNZ8(val); }
:ASL EXT16     is op8=0x17; op8b=0x34; EXT16   { local val:1 = *:1 EXT16;  C_flag = val[7,1]; V_flag = val[7,1] ^ val[6,1]; val = val << 1; *:1 EXT16 = val;  setNZ8(val); }

# = CLR: $00 => M =
:CLR IND8X     is op8=0x05; IND8X     { *:1 IND8X = 0; N_flag = 0; Z_flag = 1; V_flag = 0; C_flag = 0; }
:CLR IND8Y     is op8=0x15; IND8Y     { *:1 IND8Y = 0; N_flag = 0; Z_flag = 1; V_flag = 0; C_flag = 0; }
:CLR IND8Z     is op8=0x25; IND8Z     { *:1 IND8Z = 0; N_flag = 0; Z_flag = 1; V_flag = 0; C_flag = 0; }
:CLR IND16X    is op8=0x17; op8b=0x05; IND16X  { *:1 IND16X = 0; N_flag = 0; Z_flag = 1; V_flag = 0; C_flag = 0; }
:CLR IND16Y    is op8=0x17; op8b=0x15; IND16Y  { *:1 IND16Y = 0; N_flag = 0; Z_flag = 1; V_flag = 0; C_flag = 0; }
:CLR IND16Z    is op8=0x17; op8b=0x25; IND16Z  { *:1 IND16Z = 0; N_flag = 0; Z_flag = 1; V_flag = 0; C_flag = 0; }
:CLR EXT16     is op8=0x17; op8b=0x35; EXT16   { *:1 EXT16 = 0;  N_flag = 0; Z_flag = 1; V_flag = 0; C_flag = 0; }

# = TST: test memory byte =
:TST IND8X     is op8=0x06; IND8X     { local val:1 = *:1 IND8X; setNZ8(val); V_flag = 0; C_flag = 0; }
:TST IND8Y     is op8=0x16; IND8Y     { local val:1 = *:1 IND8Y; setNZ8(val); V_flag = 0; C_flag = 0; }
:TST IND8Z     is op8=0x26; IND8Z     { local val:1 = *:1 IND8Z; setNZ8(val); V_flag = 0; C_flag = 0; }
:TST IND16X    is op8=0x17; op8b=0x06; IND16X  { local val:1 = *:1 IND16X; setNZ8(val); V_flag = 0; C_flag = 0; }
:TST IND16Y    is op8=0x17; op8b=0x16; IND16Y  { local val:1 = *:1 IND16Y; setNZ8(val); V_flag = 0; C_flag = 0; }
:TST IND16Z    is op8=0x17; op8b=0x26; IND16Z  { local val:1 = *:1 IND16Z; setNZ8(val); V_flag = 0; C_flag = 0; }
:TST EXT16     is op8=0x17; op8b=0x36; EXT16   { local val:1 = *:1 EXT16;  setNZ8(val); V_flag = 0; C_flag = 0; }

# = ASR (memory byte) =
:ASR IND8X     is op8=0x0D; IND8X     { local val:1 = *:1 IND8X; C_flag = val[0,1]; V_flag = val[7,1] ^ val[0,1]; val = val s>> 1; *:1 IND8X = val; setNZ8(val); }
:ASR IND8Y     is op8=0x1D; IND8Y     { local val:1 = *:1 IND8Y; C_flag = val[0,1]; V_flag = val[7,1] ^ val[0,1]; val = val s>> 1; *:1 IND8Y = val; setNZ8(val); }
:ASR IND8Z     is op8=0x2D; IND8Z     { local val:1 = *:1 IND8Z; C_flag = val[0,1]; V_flag = val[7,1] ^ val[0,1]; val = val s>> 1; *:1 IND8Z = val; setNZ8(val); }
:ASR IND16X    is op8=0x17; op8b=0x0D; IND16X  { local val:1 = *:1 IND16X; C_flag = val[0,1]; V_flag = val[7,1] ^ val[0,1]; val = val s>> 1; *:1 IND16X = val; setNZ8(val); }
:ASR IND16Y    is op8=0x17; op8b=0x1D; IND16Y  { local val:1 = *:1 IND16Y; C_flag = val[0,1]; V_flag = val[7,1] ^ val[0,1]; val = val s>> 1; *:1 IND16Y = val; setNZ8(val); }
:ASR IND16Z    is op8=0x17; op8b=0x2D; IND16Z  { local val:1 = *:1 IND16Z; C_flag = val[0,1]; V_flag = val[7,1] ^ val[0,1]; val = val s>> 1; *:1 IND16Z = val; setNZ8(val); }
:ASR EXT16     is op8=0x17; op8b=0x3D; EXT16   { local val:1 = *:1 EXT16;  C_flag = val[0,1]; V_flag = val[7,1] ^ val[0,1]; val = val s>> 1; *:1 EXT16 = val;  setNZ8(val); }

# = LSR (memory byte) =
:LSR IND8X     is op8=0x0F; IND8X     { local val:1 = *:1 IND8X; C_flag = val[0,1]; val = val >> 1; *:1 IND8X = val; setNZ8(val); V_flag = N_flag ^ C_flag; }
:LSR IND8Y     is op8=0x1F; IND8Y     { local val:1 = *:1 IND8Y; C_flag = val[0,1]; val = val >> 1; *:1 IND8Y = val; setNZ8(val); V_flag = N_flag ^ C_flag; }
:LSR IND8Z     is op8=0x2F; IND8Z     { local val:1 = *:1 IND8Z; C_flag = val[0,1]; val = val >> 1; *:1 IND8Z = val; setNZ8(val); V_flag = N_flag ^ C_flag; }
:LSR IND16X    is op8=0x17; op8b=0x0F; IND16X  { local val:1 = *:1 IND16X; C_flag = val[0,1]; val = val >> 1; *:1 IND16X = val; setNZ8(val); V_flag = N_flag ^ C_flag; }
:LSR IND16Y    is op8=0x17; op8b=0x1F; IND16Y  { local val:1 = *:1 IND16Y; C_flag = val[0,1]; val = val >> 1; *:1 IND16Y = val; setNZ8(val); V_flag = N_flag ^ C_flag; }
:LSR IND16Z    is op8=0x17; op8b=0x2F; IND16Z  { local val:1 = *:1 IND16Z; C_flag = val[0,1]; val = val >> 1; *:1 IND16Z = val; setNZ8(val); V_flag = N_flag ^ C_flag; }
:LSR EXT16     is op8=0x17; op8b=0x3F; EXT16   { local val:1 = *:1 EXT16;  C_flag = val[0,1]; val = val >> 1; *:1 EXT16 = val;  setNZ8(val); V_flag = N_flag ^ C_flag; }

# = ROL (memory byte) = ROL=0x0C per CPU16RM
:ROL IND8X     is op8=0x0C; IND8X     { local val:1 = *:1 IND8X; local c:1 = C_flag; C_flag = val[7,1]; V_flag = val[7,1] ^ val[6,1]; val = (val << 1) | c; *:1 IND8X = val; setNZ8(val); }
:ROL IND8Y     is op8=0x1C; IND8Y     { local val:1 = *:1 IND8Y; local c:1 = C_flag; C_flag = val[7,1]; V_flag = val[7,1] ^ val[6,1]; val = (val << 1) | c; *:1 IND8Y = val; setNZ8(val); }
:ROL IND8Z     is op8=0x2C; IND8Z     { local val:1 = *:1 IND8Z; local c:1 = C_flag; C_flag = val[7,1]; V_flag = val[7,1] ^ val[6,1]; val = (val << 1) | c; *:1 IND8Z = val; setNZ8(val); }
:ROL IND16X    is op8=0x17; op8b=0x0C; IND16X  { local val:1 = *:1 IND16X; local c:1 = C_flag; C_flag = val[7,1]; V_flag = val[7,1] ^ val[6,1]; val = (val << 1) | c; *:1 IND16X = val; setNZ8(val); }
:ROL IND16Y    is op8=0x17; op8b=0x1C; IND16Y  { local val:1 = *:1 IND16Y; local c:1 = C_flag; C_flag = val[7,1]; V_flag = val[7,1] ^ val[6,1]; val = (val << 1) | c; *:1 IND16Y = val; setNZ8(val); }
:ROL IND16Z    is op8=0x17; op8b=0x2C; IND16Z  { local val:1 = *:1 IND16Z; local c:1 = C_flag; C_flag = val[7,1]; V_flag = val[7,1] ^ val[6,1]; val = (val << 1) | c; *:1 IND16Z = val; setNZ8(val); }
:ROL EXT16     is op8=0x17; op8b=0x3C; EXT16   { local val:1 = *:1 EXT16;  local c:1 = C_flag; C_flag = val[7,1]; V_flag = val[7,1] ^ val[6,1]; val = (val << 1) | c; *:1 EXT16 = val;  setNZ8(val); }

# = ROR (memory byte) = ROR=0x0E per CPU16RM
:ROR IND8X     is op8=0x0E; IND8X     { local val:1 = *:1 IND8X; local c:1 = C_flag; C_flag = val[0,1]; V_flag = val[7,1] ^ C_flag; val = (val >> 1) | (c << 7); *:1 IND8X = val; setNZ8(val); }
:ROR IND8Y     is op8=0x1E; IND8Y     { local val:1 = *:1 IND8Y; local c:1 = C_flag; C_flag = val[0,1]; V_flag = val[7,1] ^ C_flag; val = (val >> 1) | (c << 7); *:1 IND8Y = val; setNZ8(val); }
:ROR IND8Z     is op8=0x2E; IND8Z     { local val:1 = *:1 IND8Z; local c:1 = C_flag; C_flag = val[0,1]; V_flag = val[7,1] ^ C_flag; val = (val >> 1) | (c << 7); *:1 IND8Z = val; setNZ8(val); }
:ROR IND16X    is op8=0x17; op8b=0x0E; IND16X  { local val:1 = *:1 IND16X; local c:1 = C_flag; C_flag = val[0,1]; V_flag = val[7,1] ^ C_flag; val = (val >> 1) | (c << 7); *:1 IND16X = val; setNZ8(val); }
:ROR IND16Y    is op8=0x17; op8b=0x1E; IND16Y  { local val:1 = *:1 IND16Y; local c:1 = C_flag; C_flag = val[0,1]; V_flag = val[7,1] ^ C_flag; val = (val >> 1) | (c << 7); *:1 IND16Y = val; setNZ8(val); }
:ROR IND16Z    is op8=0x17; op8b=0x2E; IND16Z  { local val:1 = *:1 IND16Z; local c:1 = C_flag; C_flag = val[0,1]; V_flag = val[7,1] ^ C_flag; val = (val >> 1) | (c << 7); *:1 IND16Z = val; setNZ8(val); }
:ROR EXT16     is op8=0x17; op8b=0x3E; EXT16   { local val:1 = *:1 EXT16;  local c:1 = C_flag; C_flag = val[0,1]; V_flag = val[7,1] ^ C_flag; val = (val >> 1) | (c << 7); *:1 EXT16 = val;  setNZ8(val); }


# ============================================================================
# SECTION: MEMORY WORD OPERATIONS (page 3: 27xx)
# ============================================================================

:CLRW IND16X   is op8=0x27; op8b=0x05; IND16X  { *:2 IND16X = 0; N_flag = 0; Z_flag = 1; V_flag = 0; C_flag = 0; }
:CLRW IND16Y   is op8=0x27; op8b=0x15; IND16Y  { *:2 IND16Y = 0; N_flag = 0; Z_flag = 1; V_flag = 0; C_flag = 0; }
:CLRW IND16Z   is op8=0x27; op8b=0x25; IND16Z  { *:2 IND16Z = 0; N_flag = 0; Z_flag = 1; V_flag = 0; C_flag = 0; }
:CLRW EXT16    is op8=0x27; op8b=0x35; EXT16   { *:2 EXT16 = 0;  N_flag = 0; Z_flag = 1; V_flag = 0; C_flag = 0; }

:COMW IND16X   is op8=0x27; op8b=0x00; IND16X  { local val:2 = *:2 IND16X; val = ~val; *:2 IND16X = val; setNZ16(val); V_flag = 0; C_flag = 1; }
:COMW IND16Y   is op8=0x27; op8b=0x10; IND16Y  { local val:2 = *:2 IND16Y; val = ~val; *:2 IND16Y = val; setNZ16(val); V_flag = 0; C_flag = 1; }
:COMW IND16Z   is op8=0x27; op8b=0x20; IND16Z  { local val:2 = *:2 IND16Z; val = ~val; *:2 IND16Z = val; setNZ16(val); V_flag = 0; C_flag = 1; }
:COMW EXT16    is op8=0x27; op8b=0x30; EXT16   { local val:2 = *:2 EXT16;  val = ~val; *:2 EXT16 = val;  setNZ16(val); V_flag = 0; C_flag = 1; }

:NEGW IND16X   is op8=0x27; op8b=0x02; IND16X  { local val:2 = *:2 IND16X; V_flag = (val == 0x8000); C_flag = (val != 0); val = -val; *:2 IND16X = val; setNZ16(val); }
:NEGW IND16Y   is op8=0x27; op8b=0x12; IND16Y  { local val:2 = *:2 IND16Y; V_flag = (val == 0x8000); C_flag = (val != 0); val = -val; *:2 IND16Y = val; setNZ16(val); }
:NEGW IND16Z   is op8=0x27; op8b=0x22; IND16Z  { local val:2 = *:2 IND16Z; V_flag = (val == 0x8000); C_flag = (val != 0); val = -val; *:2 IND16Z = val; setNZ16(val); }
:NEGW EXT16    is op8=0x27; op8b=0x32; EXT16   { local val:2 = *:2 EXT16;  V_flag = (val == 0x8000); C_flag = (val != 0); val = -val; *:2 EXT16 = val;  setNZ16(val); }

:DECW IND16X   is op8=0x27; op8b=0x01; IND16X  { local val:2 = *:2 IND16X; V_flag = (val == 0x8000); val = val - 1; *:2 IND16X = val; setNZ16(val); }
:DECW IND16Y   is op8=0x27; op8b=0x11; IND16Y  { local val:2 = *:2 IND16Y; V_flag = (val == 0x8000); val = val - 1; *:2 IND16Y = val; setNZ16(val); }
:DECW IND16Z   is op8=0x27; op8b=0x21; IND16Z  { local val:2 = *:2 IND16Z; V_flag = (val == 0x8000); val = val - 1; *:2 IND16Z = val; setNZ16(val); }
:DECW EXT16    is op8=0x27; op8b=0x31; EXT16   { local val:2 = *:2 EXT16;  V_flag = (val == 0x8000); val = val - 1; *:2 EXT16 = val;  setNZ16(val); }

:INCW IND16X   is op8=0x27; op8b=0x03; IND16X  { local val:2 = *:2 IND16X; V_flag = (val == 0x7FFF); val = val + 1; *:2 IND16X = val; setNZ16(val); }
:INCW IND16Y   is op8=0x27; op8b=0x13; IND16Y  { local val:2 = *:2 IND16Y; V_flag = (val == 0x7FFF); val = val + 1; *:2 IND16Y = val; setNZ16(val); }
:INCW IND16Z   is op8=0x27; op8b=0x23; IND16Z  { local val:2 = *:2 IND16Z; V_flag = (val == 0x7FFF); val = val + 1; *:2 IND16Z = val; setNZ16(val); }
:INCW EXT16    is op8=0x27; op8b=0x33; EXT16   { local val:2 = *:2 EXT16;  V_flag = (val == 0x7FFF); val = val + 1; *:2 EXT16 = val;  setNZ16(val); }

:TSTW IND16X   is op8=0x27; op8b=0x06; IND16X  { local val:2 = *:2 IND16X; setNZ16(val); V_flag = 0; C_flag = 0; }
:TSTW IND16Y   is op8=0x27; op8b=0x16; IND16Y  { local val:2 = *:2 IND16Y; setNZ16(val); V_flag = 0; C_flag = 0; }
:TSTW IND16Z   is op8=0x27; op8b=0x26; IND16Z  { local val:2 = *:2 IND16Z; setNZ16(val); V_flag = 0; C_flag = 0; }
:TSTW EXT16    is op8=0x27; op8b=0x36; EXT16   { local val:2 = *:2 EXT16;  setNZ16(val); V_flag = 0; C_flag = 0; }

:ASLW IND16X   is op8=0x27; op8b=0x04; IND16X  { local val:2 = *:2 IND16X; C_flag = val[15,1]; V_flag = val[15,1] ^ val[14,1]; val = val << 1; *:2 IND16X = val; setNZ16(val); }
:ASLW IND16Y   is op8=0x27; op8b=0x14; IND16Y  { local val:2 = *:2 IND16Y; C_flag = val[15,1]; V_flag = val[15,1] ^ val[14,1]; val = val << 1; *:2 IND16Y = val; setNZ16(val); }
:ASLW IND16Z   is op8=0x27; op8b=0x24; IND16Z  { local val:2 = *:2 IND16Z; C_flag = val[15,1]; V_flag = val[15,1] ^ val[14,1]; val = val << 1; *:2 IND16Z = val; setNZ16(val); }
:ASLW EXT16    is op8=0x27; op8b=0x34; EXT16   { local val:2 = *:2 EXT16;  C_flag = val[15,1]; V_flag = val[15,1] ^ val[14,1]; val = val << 1; *:2 EXT16 = val;  setNZ16(val); }

:ASRW IND16X   is op8=0x27; op8b=0x0D; IND16X  { local val:2 = *:2 IND16X; C_flag = val[0,1]; V_flag = val[15,1] ^ val[0,1]; val = val s>> 1; *:2 IND16X = val; setNZ16(val); }
:ASRW IND16Y   is op8=0x27; op8b=0x1D; IND16Y  { local val:2 = *:2 IND16Y; C_flag = val[0,1]; V_flag = val[15,1] ^ val[0,1]; val = val s>> 1; *:2 IND16Y = val; setNZ16(val); }
:ASRW IND16Z   is op8=0x27; op8b=0x2D; IND16Z  { local val:2 = *:2 IND16Z; C_flag = val[0,1]; V_flag = val[15,1] ^ val[0,1]; val = val s>> 1; *:2 IND16Z = val; setNZ16(val); }
:ASRW EXT16    is op8=0x27; op8b=0x3D; EXT16   { local val:2 = *:2 EXT16;  C_flag = val[0,1]; V_flag = val[15,1] ^ val[0,1]; val = val s>> 1; *:2 EXT16 = val;  setNZ16(val); }

:LSRW IND16X   is op8=0x27; op8b=0x0F; IND16X  { local val:2 = *:2 IND16X; C_flag = val[0,1]; val = val >> 1; *:2 IND16X = val; setNZ16(val); V_flag = N_flag ^ C_flag; }
:LSRW IND16Y   is op8=0x27; op8b=0x1F; IND16Y  { local val:2 = *:2 IND16Y; C_flag = val[0,1]; val = val >> 1; *:2 IND16Y = val; setNZ16(val); V_flag = N_flag ^ C_flag; }
:LSRW IND16Z   is op8=0x27; op8b=0x2F; IND16Z  { local val:2 = *:2 IND16Z; C_flag = val[0,1]; val = val >> 1; *:2 IND16Z = val; setNZ16(val); V_flag = N_flag ^ C_flag; }
:LSRW EXT16    is op8=0x27; op8b=0x3F; EXT16   { local val:2 = *:2 EXT16;  C_flag = val[0,1]; val = val >> 1; *:2 EXT16 = val;  setNZ16(val); V_flag = N_flag ^ C_flag; }

:ROLW IND16X   is op8=0x27; op8b=0x0C; IND16X  { local val:2 = *:2 IND16X; local c:2 = zext(C_flag); C_flag = val[15,1]; V_flag = val[15,1] ^ val[14,1]; val = (val << 1) | c; *:2 IND16X = val; setNZ16(val); }
:ROLW IND16Y   is op8=0x27; op8b=0x1C; IND16Y  { local val:2 = *:2 IND16Y; local c:2 = zext(C_flag); C_flag = val[15,1]; V_flag = val[15,1] ^ val[14,1]; val = (val << 1) | c; *:2 IND16Y = val; setNZ16(val); }
:ROLW IND16Z   is op8=0x27; op8b=0x2C; IND16Z  { local val:2 = *:2 IND16Z; local c:2 = zext(C_flag); C_flag = val[15,1]; V_flag = val[15,1] ^ val[14,1]; val = (val << 1) | c; *:2 IND16Z = val; setNZ16(val); }
:ROLW EXT16    is op8=0x27; op8b=0x3C; EXT16   { local val:2 = *:2 EXT16;  local c:2 = zext(C_flag); C_flag = val[15,1]; V_flag = val[15,1] ^ val[14,1]; val = (val << 1) | c; *:2 EXT16 = val;  setNZ16(val); }

:RORW IND16X   is op8=0x27; op8b=0x0E; IND16X  { local val:2 = *:2 IND16X; local c:2 = zext(C_flag) << 15; C_flag = val[0,1]; V_flag = val[15,1] ^ C_flag; val = (val >> 1) | c; *:2 IND16X = val; setNZ16(val); }
:RORW IND16Y   is op8=0x27; op8b=0x1E; IND16Y  { local val:2 = *:2 IND16Y; local c:2 = zext(C_flag) << 15; C_flag = val[0,1]; V_flag = val[15,1] ^ C_flag; val = (val >> 1) | c; *:2 IND16Y = val; setNZ16(val); }
:RORW IND16Z   is op8=0x27; op8b=0x2E; IND16Z  { local val:2 = *:2 IND16Z; local c:2 = zext(C_flag) << 15; C_flag = val[0,1]; V_flag = val[15,1] ^ C_flag; val = (val >> 1) | c; *:2 IND16Z = val; setNZ16(val); }
:RORW EXT16    is op8=0x27; op8b=0x3E; EXT16   { local val:2 = *:2 EXT16;  local c:2 = zext(C_flag) << 15; C_flag = val[0,1]; V_flag = val[15,1] ^ C_flag; val = (val >> 1) | c; *:2 EXT16 = val;  setNZ16(val); }


# ============================================================================
# SECTION: PSHA/PSHB/PULA/PULB  (Stack byte operations)
# ============================================================================

:PSHA   is op8=0x37; op8b=0x08  { SSP = SSP - 2; *:1 (SSP+1) = A; }
:PSHB   is op8=0x37; op8b=0x18  { SSP = SSP - 2; *:1 (SSP+1) = B; }
:PULA   is op8=0x37; op8b=0x09  { A = *:1 (SSP+1); SSP = SSP + 2; }
:PULB   is op8=0x37; op8b=0x19  { B = *:1 (SSP+1); SSP = SSP + 2; }

# ============================================================================
# SECTION: PSHM / PULM (Push/Pull Multiple Registers)
# ============================================================================
# Register lists are expanded into 256-variant sub-constructor tables via 
# "68HC16_PSHM_PULM.sinc" to handle Ghidra display and stack P-code logic.
#
# PSHM Mask (Bit 0-6): D, E, IX, IY, IZ, K, CCR  (Bit 7 reserved)
# PULM Mask (Bit 0-6): CCR, K, IZ, IY, IX, E, D  (Bit 7 reserved)
#
# Execution Order: 
#   PSHM: High bits first (CCR -> D) to place D at lowest address.
#   PULM: Low bits first (D -> CCR) to pull from lowest address first.
# ============================================================================

@include "68HC16_PSHM_PULM.sinc"

# The syntax [ regs = regmask; ] explicitly maps the 'regmask' token field 
# to the sub-constructor tables defined in the included file.

:PSHM pshmList is op8=0x34; pshmList {
    build pshmList;
}

:PULM pulmList is op8=0x35; pulmList {
    build pulmList;
}


# ============================================================================
# SECTION: DSP / MAC INSTRUCTIONS (basics)
# ============================================================================

# = CLRM: Clear MAC Accumulator =
:CLRM   is op8=0x27; op8b=0xB7  { AM = 0; AM_EXT = 0; MV_flag = 0; EV_flag = 0; }

# = ASLM / ASRM =
:ASLM   is op8=0x27; op8b=0xB6  { local c:1 = AM[31,1]; AM = AM << 1; AM_EXT = (AM_EXT << 1) | c; }
:ASRM   is op8=0x27; op8b=0xBA  { local c:1 = AM_EXT[0,1]; AM = (AM s>> 1); AM[31,1] = c; }

# = LDHI: Load HR and IR (used to initialize MAC before first MAC instruction) =
# Opcode: 27B0, INH (no operand), 8 cycles
# Operation: (M:M+1)X => HR, (M:M+1)Y => IR
# Loads HR from the word at (XK:IX) and IR from the word at (YK:IY).
# No condition codes affected.
:LDHI   is op8=0x27; op8b=0xB0 {
    local xaddr:3 = (zext(XK:1) << 16) | zext(IX:2);
    HR = *:2 xaddr;
    local yaddr:3 = (zext(YK:1) << 16) | zext(IY:2);
    IR = *:2 yaddr;
}

# = FMULS: Fractional Multiply Signed =
:FMULS  is op8=0x37; op8b=0x27  {
    local prod:4 = sext(E:2) * sext(D:2);
    prod = prod << 1;
    E = prod[16,16];
    D = prod[0,16];
}

# = ACE: Add E to AM =
:ACE    is op8=0x37; op8b=0x22  { AM = AM + sext(E:2); }

# = ACED: Add E:D to AM =
:ACED   is op8=0x37; op8b=0x23  { local ed:4 = (zext(E:2) << 16) | zext(D:2); AM = AM + ed; }


# ============================================================================
# SECTION: E ACCUMULATOR (page 4: 37xx)
# Only has IND16 and EXT modes (no IND8)
# ============================================================================

# = LDE =
:LDE "#"^imm16    is op8=0x37; op8b=0x35; imm16  { E = imm16; setNZ16(E); V_flag = 0; }
:LDE IND16X       is op8=0x37; op8b=0x45; IND16X  { E = *:2 IND16X; setNZ16(E); V_flag = 0; }
:LDE IND16Y       is op8=0x37; op8b=0x55; IND16Y  { E = *:2 IND16Y; setNZ16(E); V_flag = 0; }
:LDE IND16Z       is op8=0x37; op8b=0x65; IND16Z  { E = *:2 IND16Z; setNZ16(E); V_flag = 0; }
:LDE EXT16        is op8=0x37; op8b=0x75; EXT16   { E = *:2 EXT16;  setNZ16(E); V_flag = 0; }

# = STE =
:STE IND16X       is op8=0x37; op8b=0x4A; IND16X  { *:2 IND16X = E; setNZ16(E); V_flag = 0; }
:STE IND16Y       is op8=0x37; op8b=0x5A; IND16Y  { *:2 IND16Y = E; setNZ16(E); V_flag = 0; }
:STE IND16Z       is op8=0x37; op8b=0x6A; IND16Z  { *:2 IND16Z = E; setNZ16(E); V_flag = 0; }
:STE EXT16        is op8=0x37; op8b=0x7A; EXT16   { *:2 EXT16  = E; setNZ16(E); V_flag = 0; }

# = ADDE =
:ADDE "#"^simm8   is op8=0x7C; simm8   { local val:2 = sext(simm8:1); addFlags16(E, val); E = E + val; setNZ16(E); }
:ADDE "#"^imm16   is op8=0x37; op8b=0x31; imm16  { local val:2 = imm16; addFlags16(E, val); E = E + val; setNZ16(E); }
:ADDE IND16X      is op8=0x37; op8b=0x41; IND16X  { local val:2 = *:2 IND16X; addFlags16(E, val); E = E + val; setNZ16(E); }
:ADDE IND16Y      is op8=0x37; op8b=0x51; IND16Y  { local val:2 = *:2 IND16Y; addFlags16(E, val); E = E + val; setNZ16(E); }
:ADDE IND16Z      is op8=0x37; op8b=0x61; IND16Z  { local val:2 = *:2 IND16Z; addFlags16(E, val); E = E + val; setNZ16(E); }
:ADDE EXT16       is op8=0x37; op8b=0x71; EXT16   { local val:2 = *:2 EXT16;  addFlags16(E, val); E = E + val; setNZ16(E); }

# = SUBE =
:SUBE "#"^imm16   is op8=0x37; op8b=0x30; imm16  { local val:2 = imm16; subFlags16(E, val); E = E - val; setNZ16(E); }
:SUBE IND16X      is op8=0x37; op8b=0x40; IND16X  { local val:2 = *:2 IND16X; subFlags16(E, val); E = E - val; setNZ16(E); }
:SUBE IND16Y      is op8=0x37; op8b=0x50; IND16Y  { local val:2 = *:2 IND16Y; subFlags16(E, val); E = E - val; setNZ16(E); }
:SUBE IND16Z      is op8=0x37; op8b=0x60; IND16Z  { local val:2 = *:2 IND16Z; subFlags16(E, val); E = E - val; setNZ16(E); }
:SUBE EXT16       is op8=0x37; op8b=0x70; EXT16   { local val:2 = *:2 EXT16;  subFlags16(E, val); E = E - val; setNZ16(E); }

# = CPE =
:CPE "#"^imm16    is op8=0x37; op8b=0x38; imm16  { local val:2 = imm16; local tmp:2 = E - val; subFlags16(E, val); setNZ16(tmp); }
:CPE IND16X       is op8=0x37; op8b=0x48; IND16X  { local val:2 = *:2 IND16X; local tmp:2 = E - val; subFlags16(E, val); setNZ16(tmp); }
:CPE IND16Y       is op8=0x37; op8b=0x58; IND16Y  { local val:2 = *:2 IND16Y; local tmp:2 = E - val; subFlags16(E, val); setNZ16(tmp); }
:CPE IND16Z       is op8=0x37; op8b=0x68; IND16Z  { local val:2 = *:2 IND16Z; local tmp:2 = E - val; subFlags16(E, val); setNZ16(tmp); }
:CPE EXT16        is op8=0x37; op8b=0x78; EXT16   { local val:2 = *:2 EXT16;  local tmp:2 = E - val; subFlags16(E, val); setNZ16(tmp); }

# = ANDE =
:ANDE "#"^imm16   is op8=0x37; op8b=0x36; imm16  { E = E & imm16; setNZ16(E); V_flag = 0; }
:ANDE IND16X      is op8=0x37; op8b=0x46; IND16X  { E = E & (*:2 IND16X); setNZ16(E); V_flag = 0; }
:ANDE IND16Y      is op8=0x37; op8b=0x56; IND16Y  { E = E & (*:2 IND16Y); setNZ16(E); V_flag = 0; }
:ANDE IND16Z      is op8=0x37; op8b=0x66; IND16Z  { E = E & (*:2 IND16Z); setNZ16(E); V_flag = 0; }
:ANDE EXT16       is op8=0x37; op8b=0x76; EXT16   { E = E & (*:2 EXT16);  setNZ16(E); V_flag = 0; }

# = ORE =
:ORE "#"^imm16    is op8=0x37; op8b=0x37; imm16  { E = E | imm16; setNZ16(E); V_flag = 0; }
:ORE IND16X       is op8=0x37; op8b=0x47; IND16X  { E = E | (*:2 IND16X); setNZ16(E); V_flag = 0; }
:ORE IND16Y       is op8=0x37; op8b=0x57; IND16Y  { E = E | (*:2 IND16Y); setNZ16(E); V_flag = 0; }
:ORE IND16Z       is op8=0x37; op8b=0x67; IND16Z  { E = E | (*:2 IND16Z); setNZ16(E); V_flag = 0; }
:ORE EXT16        is op8=0x37; op8b=0x77; EXT16   { E = E | (*:2 EXT16);  setNZ16(E); V_flag = 0; }

# = EORE =
:EORE "#"^imm16   is op8=0x37; op8b=0x34; imm16  { E = E ^ imm16; setNZ16(E); V_flag = 0; }
:EORE IND16X      is op8=0x37; op8b=0x44; IND16X  { E = E ^ (*:2 IND16X); setNZ16(E); V_flag = 0; }
:EORE IND16Y      is op8=0x37; op8b=0x54; IND16Y  { E = E ^ (*:2 IND16Y); setNZ16(E); V_flag = 0; }
:EORE IND16Z      is op8=0x37; op8b=0x64; IND16Z  { E = E ^ (*:2 IND16Z); setNZ16(E); V_flag = 0; }
:EORE EXT16       is op8=0x37; op8b=0x74; EXT16   { E = E ^ (*:2 EXT16);  setNZ16(E); V_flag = 0; }


# ============================================================================
# SECTION: COMPARE INDEX REGISTERS (CPX, CPY, CPZ, CPS)
# ============================================================================

:CPX IND8X     is op8=0x4C; IND8X     { local val:2 = *:2 IND8X; local tmp:2 = IX - val; subFlags16(IX, val); setNZ16(tmp); }
:CPX IND8Y     is op8=0x5C; IND8Y     { local val:2 = *:2 IND8Y; local tmp:2 = IX - val; subFlags16(IX, val); setNZ16(tmp); }
:CPX IND8Z     is op8=0x6C; IND8Z     { local val:2 = *:2 IND8Z; local tmp:2 = IX - val; subFlags16(IX, val); setNZ16(tmp); }
:CPX "#"^imm16 is op8=0x37; op8b=0x7C; imm16  { local val:2 = imm16; local tmp:2 = IX - val; subFlags16(IX, val); setNZ16(tmp); }
:CPX IND16X    is op8=0x17; op8b=0x4C; IND16X  { local val:2 = *:2 IND16X; local tmp:2 = IX - val; subFlags16(IX, val); setNZ16(tmp); }
:CPX IND16Y    is op8=0x17; op8b=0x5C; IND16Y  { local val:2 = *:2 IND16Y; local tmp:2 = IX - val; subFlags16(IX, val); setNZ16(tmp); }
:CPX IND16Z    is op8=0x17; op8b=0x6C; IND16Z  { local val:2 = *:2 IND16Z; local tmp:2 = IX - val; subFlags16(IX, val); setNZ16(tmp); }
:CPX EXT16     is op8=0x17; op8b=0x7C; EXT16   { local val:2 = *:2 EXT16;  local tmp:2 = IX - val; subFlags16(IX, val); setNZ16(tmp); }

:CPY IND8X     is op8=0x4D; IND8X     { local val:2 = *:2 IND8X; local tmp:2 = IY - val; subFlags16(IY, val); setNZ16(tmp); }
:CPY IND8Y     is op8=0x5D; IND8Y     { local val:2 = *:2 IND8Y; local tmp:2 = IY - val; subFlags16(IY, val); setNZ16(tmp); }
:CPY IND8Z     is op8=0x6D; IND8Z     { local val:2 = *:2 IND8Z; local tmp:2 = IY - val; subFlags16(IY, val); setNZ16(tmp); }
:CPY "#"^imm16 is op8=0x37; op8b=0x7D; imm16  { local val:2 = imm16; local tmp:2 = IY - val; subFlags16(IY, val); setNZ16(tmp); }
:CPY IND16X    is op8=0x17; op8b=0x4D; IND16X  { local val:2 = *:2 IND16X; local tmp:2 = IY - val; subFlags16(IY, val); setNZ16(tmp); }
:CPY IND16Y    is op8=0x17; op8b=0x5D; IND16Y  { local val:2 = *:2 IND16Y; local tmp:2 = IY - val; subFlags16(IY, val); setNZ16(tmp); }
:CPY IND16Z    is op8=0x17; op8b=0x6D; IND16Z  { local val:2 = *:2 IND16Z; local tmp:2 = IY - val; subFlags16(IY, val); setNZ16(tmp); }
:CPY EXT16     is op8=0x17; op8b=0x7D; EXT16   { local val:2 = *:2 EXT16;  local tmp:2 = IY - val; subFlags16(IY, val); setNZ16(tmp); }

:CPZ IND8X     is op8=0x4E; IND8X     { local val:2 = *:2 IND8X; local tmp:2 = IZ - val; subFlags16(IZ, val); setNZ16(tmp); }
:CPZ IND8Y     is op8=0x5E; IND8Y     { local val:2 = *:2 IND8Y; local tmp:2 = IZ - val; subFlags16(IZ, val); setNZ16(tmp); }
:CPZ IND8Z     is op8=0x6E; IND8Z     { local val:2 = *:2 IND8Z; local tmp:2 = IZ - val; subFlags16(IZ, val); setNZ16(tmp); }
:CPZ "#"^imm16 is op8=0x37; op8b=0x7E; imm16  { local val:2 = imm16; local tmp:2 = IZ - val; subFlags16(IZ, val); setNZ16(tmp); }
:CPZ IND16X    is op8=0x17; op8b=0x4E; IND16X  { local val:2 = *:2 IND16X; local tmp:2 = IZ - val; subFlags16(IZ, val); setNZ16(tmp); }
:CPZ IND16Y    is op8=0x17; op8b=0x5E; IND16Y  { local val:2 = *:2 IND16Y; local tmp:2 = IZ - val; subFlags16(IZ, val); setNZ16(tmp); }
:CPZ IND16Z    is op8=0x17; op8b=0x6E; IND16Z  { local val:2 = *:2 IND16Z; local tmp:2 = IZ - val; subFlags16(IZ, val); setNZ16(tmp); }
:CPZ EXT16     is op8=0x17; op8b=0x7E; EXT16   { local val:2 = *:2 EXT16;  local tmp:2 = IZ - val; subFlags16(IZ, val); setNZ16(tmp); }

:CPS IND8X     is op8=0x4F; IND8X     { local val:2 = *:2 IND8X; local tmp:2 = SP - val; subFlags16(SP, val); setNZ16(tmp); }
:CPS IND8Y     is op8=0x5F; IND8Y     { local val:2 = *:2 IND8Y; local tmp:2 = SP - val; subFlags16(SP, val); setNZ16(tmp); }
:CPS IND8Z     is op8=0x6F; IND8Z     { local val:2 = *:2 IND8Z; local tmp:2 = SP - val; subFlags16(SP, val); setNZ16(tmp); }
:CPS "#"^imm16 is op8=0x37; op8b=0x7F; imm16  { local val:2 = imm16; local tmp:2 = SP - val; subFlags16(SP, val); setNZ16(tmp); }
:CPS IND16X    is op8=0x17; op8b=0x4F; IND16X  { local val:2 = *:2 IND16X; local tmp:2 = SP - val; subFlags16(SP, val); setNZ16(tmp); }
:CPS IND16Y    is op8=0x17; op8b=0x5F; IND16Y  { local val:2 = *:2 IND16Y; local tmp:2 = SP - val; subFlags16(SP, val); setNZ16(tmp); }
:CPS IND16Z    is op8=0x17; op8b=0x6F; IND16Z  { local val:2 = *:2 IND16Z; local tmp:2 = SP - val; subFlags16(SP, val); setNZ16(tmp); }
:CPS EXT16     is op8=0x17; op8b=0x7F; EXT16   { local val:2 = *:2 EXT16;  local tmp:2 = SP - val; subFlags16(SP, val); setNZ16(tmp); }


# ============================================================================
# SECTION: MOVB / MOVW  (Block Move)
# ============================================================================

# MOVB IXP to EXT: (XK:IX) => M(EXT); IX = IX + sext(ff)
:MOVB imm8^",X,"^addr16  is op8=0x30; imm8; addr16 {
    local src:3 = (zext(XK:1) << 16) | zext(IX:2);
    local dst:3 = (zext(EK:1) << 16) | zext(addr16:2);
    local val:1 = *:1 src;
    *:1 dst = val;
    IX = IX + sext(imm8:1);
    setNZ8(val); V_flag = 0;
}

# MOVB EXT to IXP: (M(EXT)) => (XK:IX); IX = IX + sext(ff)
:MOVB addr16^","^imm8^",X"  is op8=0x32; imm8; addr16 {
    local dst:3 = (zext(XK:1) << 16) | zext(IX:2);
    local src:3 = (zext(EK:1) << 16) | zext(addr16:2);
    local val:1 = *:1 src;
    *:1 dst = val;
    IX = IX + sext(imm8:1);
    setNZ8(val); V_flag = 0;
}

# MOVW IXP to EXT
:MOVW imm8^",X,"^addr16  is op8=0x31; imm8; addr16 {
    local src:3 = (zext(XK:1) << 16) | zext(IX:2);
    local dst:3 = (zext(EK:1) << 16) | zext(addr16:2);
    local val:2 = *:2 src;
    *:2 dst = val;
    IX = IX + sext(imm8:1);
    setNZ16(val); V_flag = 0;
}

# MOVW EXT to IXP
:MOVW addr16^","^imm8^",X"  is op8=0x33; imm8; addr16 {
    local dst:3 = (zext(XK:1) << 16) | zext(IX:2);
    local src:3 = (zext(EK:1) << 16) | zext(addr16:2);
    local val:2 = *:2 src;
    *:2 dst = val;
    IX = IX + sext(imm8:1);
    setNZ16(val); V_flag = 0;
}

# MOVB EXT to EXT: 37 FE hh ll hh ll
:MOVB addr16^","^addr16_2  is op8=0x37; op8b=0xFE; addr16; addr16_2 {
    local src:3 = (zext(EK:1) << 16) | zext(addr16:2);
    local dst:3 = (zext(EK:1) << 16) | zext(addr16_2:2);
    local val:1 = *:1 src;
    *:1 dst = val;
    setNZ8(val); V_flag = 0;
}

# MOVW EXT to EXT: 37 FF hh ll hh ll
:MOVW addr16^","^addr16_2  is op8=0x37; op8b=0xFF; addr16; addr16_2 {
    local src:3 = (zext(EK:1) << 16) | zext(addr16:2);
    local dst:3 = (zext(EK:1) << 16) | zext(addr16_2:2);
    local val:2 = *:2 src;
    *:2 dst = val;
    setNZ16(val); V_flag = 0;
}


# ============================================================================
# SECTION: LDED / STED (Load/Store E:D longword)
# ============================================================================
:LDED EXT16  is op8=0x27; op8b=0x71; EXT16 {
    E = *:2 EXT16;
    local addr2:3 = EXT16 + 2;
    D = *:2 addr2;
}

:STED EXT16  is op8=0x27; op8b=0x73; EXT16 {
    *:2 EXT16 = E;
    local addr2:3 = EXT16 + 2;
    *:2 addr2 = D;
}


# ============================================================================
# SECTION: WAI / LPSTOP
# ============================================================================
:WAI    is op8=0x27; op8b=0xF3 {
    HaltUntilInterrupt();
}

:LPSTOP  is op8=0x27; op8b=0xF1 {
    HaltUntilInterrupt();
    # Low power stop - halt clocks until interrupt
}


# ============================================================================
# SECTION: B-ACCUMULATOR E,X / E,Y / E,Z MODES (page 3: 27Cx/27Dx/27Ex)
# These were missing from the original B-accumulator section
# ============================================================================

# = SBCB E,offset =
:SBCB EOFFX     is op8=0x27; op8b=0xC2; EOFFX   { local val:1 = *:1 EOFFX;  local c:1 = C_flag; subFlags(B, val+c); B = B - val - c; setNZ8(B); }
:SBCB EOFFY     is op8=0x27; op8b=0xD2; EOFFY   { local val:1 = *:1 EOFFY;  local c:1 = C_flag; subFlags(B, val+c); B = B - val - c; setNZ8(B); }
:SBCB EOFFZ     is op8=0x27; op8b=0xE2; EOFFZ   { local val:1 = *:1 EOFFZ;  local c:1 = C_flag; subFlags(B, val+c); B = B - val - c; setNZ8(B); }

# = ADCB E,offset =
:ADCB EOFFX     is op8=0x27; op8b=0xC3; EOFFX   { local val:1 = *:1 EOFFX;  local c:1 = C_flag; addFlags(B, val+c); B = B + val + c; setNZ8(B); }
:ADCB EOFFY     is op8=0x27; op8b=0xD3; EOFFY   { local val:1 = *:1 EOFFY;  local c:1 = C_flag; addFlags(B, val+c); B = B + val + c; setNZ8(B); }
:ADCB EOFFZ     is op8=0x27; op8b=0xE3; EOFFZ   { local val:1 = *:1 EOFFZ;  local c:1 = C_flag; addFlags(B, val+c); B = B + val + c; setNZ8(B); }

# = EORB E,offset =
:EORB EOFFX     is op8=0x27; op8b=0xC4; EOFFX   { B = B ^ (*:1 EOFFX);  setNZ8(B); V_flag = 0; }
:EORB EOFFY     is op8=0x27; op8b=0xD4; EOFFY   { B = B ^ (*:1 EOFFY);  setNZ8(B); V_flag = 0; }
:EORB EOFFZ     is op8=0x27; op8b=0xE4; EOFFZ   { B = B ^ (*:1 EOFFZ);  setNZ8(B); V_flag = 0; }

# = ANDB E,offset =
:ANDB EOFFX     is op8=0x27; op8b=0xC6; EOFFX   { B = B & (*:1 EOFFX);  setNZ8(B); V_flag = 0; }
:ANDB EOFFY     is op8=0x27; op8b=0xD6; EOFFY   { B = B & (*:1 EOFFY);  setNZ8(B); V_flag = 0; }
:ANDB EOFFZ     is op8=0x27; op8b=0xE6; EOFFZ   { B = B & (*:1 EOFFZ);  setNZ8(B); V_flag = 0; }

# = ORAB E,offset =
:ORAB EOFFX     is op8=0x27; op8b=0xC7; EOFFX   { B = B | (*:1 EOFFX);  setNZ8(B); V_flag = 0; }
:ORAB EOFFY     is op8=0x27; op8b=0xD7; EOFFY   { B = B | (*:1 EOFFY);  setNZ8(B); V_flag = 0; }
:ORAB EOFFZ     is op8=0x27; op8b=0xE7; EOFFZ   { B = B | (*:1 EOFFZ);  setNZ8(B); V_flag = 0; }

# = CMPB E,offset =
:CMPB EOFFX     is op8=0x27; op8b=0xC8; EOFFX   { local val:1 = *:1 EOFFX;  local tmp:1 = B - val; subFlags(B, val); setNZ8(tmp); }
:CMPB EOFFY     is op8=0x27; op8b=0xD8; EOFFY   { local val:1 = *:1 EOFFY;  local tmp:1 = B - val; subFlags(B, val); setNZ8(tmp); }
:CMPB EOFFZ     is op8=0x27; op8b=0xE8; EOFFZ   { local val:1 = *:1 EOFFZ;  local tmp:1 = B - val; subFlags(B, val); setNZ8(tmp); }

# = BITB E,offset =
:BITB EOFFX     is op8=0x27; op8b=0xC9; EOFFX   { local tmp:1 = B & (*:1 EOFFX);  setNZ8(tmp); V_flag = 0; }
:BITB EOFFY     is op8=0x27; op8b=0xD9; EOFFY   { local tmp:1 = B & (*:1 EOFFY);  setNZ8(tmp); V_flag = 0; }
:BITB EOFFZ     is op8=0x27; op8b=0xE9; EOFFZ   { local tmp:1 = B & (*:1 EOFFZ);  setNZ8(tmp); V_flag = 0; }


# ============================================================================
# SECTION: ROLD / ROLE / RORD / RORE (register rotates, D and E)
# ============================================================================
:ROLD   is op8=0x27; op8b=0xFC  { local c:2 = zext(C_flag); C_flag = D[15,1]; V_flag = D[15,1] ^ D[14,1]; D = (D << 1) | c; setNZ16(D); }
:ROLE   is op8=0x27; op8b=0x7C  { local c:2 = zext(C_flag); C_flag = E[15,1]; V_flag = E[15,1] ^ E[14,1]; E = (E << 1) | c; setNZ16(E); }
:RORD   is op8=0x27; op8b=0xFE  { local c:2 = zext(C_flag) << 15; C_flag = D[0,1]; V_flag = D[15,1] ^ C_flag; D = (D >> 1) | c; setNZ16(D); }
:RORE   is op8=0x27; op8b=0x7E  { local c:2 = zext(C_flag) << 15; C_flag = E[0,1]; V_flag = E[15,1] ^ C_flag; E = (E >> 1) | c; setNZ16(E); }


# ============================================================================
# SECTION: BCLR - Clear Bit(s) in memory byte
# (M) & ~(Mask) => M
# Flags: N=delta Z=delta V=0 C=--
# IND8 modes use prefix 0x17; IND16/EXT modes are unprefixed
# Encoding: [prefix] opcode mask8 offset/addr
# ============================================================================

# BCLR IND8,X: 17 08 mm ff
:BCLR imm8_2^",X,#"^mask8  is op8=0x17; op8b=0x08; mask8; imm8_2 {
    local off:1 = imm8_2;
    local ea:3 = (zext(XK:1) << 16) | zext(IX + zext(off));
    local val:1 = *:1 ea;
    local m:1 = mask8;
    val = val & (~m);
    *:1 ea = val;
    setNZ8(val); V_flag = 0;
}

# BCLR IND8,Y: 17 18 mm ff
:BCLR imm8_2^",Y,#"^mask8  is op8=0x17; op8b=0x18; mask8; imm8_2 {
    local off:1 = imm8_2;
    local ea:3 = (zext(YK:1) << 16) | zext(IY + zext(off));
    local val:1 = *:1 ea;
    local m:1 = mask8;
    val = val & (~m);
    *:1 ea = val;
    setNZ8(val); V_flag = 0;
}

# BCLR IND8,Z: 17 28 mm ff
:BCLR imm8_2^",Z,#"^mask8  is op8=0x17; op8b=0x28; mask8; imm8_2 & ctxZK{
    local bank:1 = ctxZK;
    local off:1 = imm8_2;
    local ea:3 = (zext(bank) << 16) | zext(IZ + zext(off));
    local val:1 = *:1 ea;
    local m:1 = mask8;
    val = val & (~m);
    *:1 ea = val;
    setNZ8(val); V_flag = 0;
}

# BCLR IND16,X: 08 mm gggg
:BCLR simm16^",X,#"^mask8  is op8=0x08; mask8; simm16 {
    local off:2 = simm16;
    local ea:3 = (zext(XK:1) << 16) | zext(IX + off);
    local val:1 = *:1 ea;
