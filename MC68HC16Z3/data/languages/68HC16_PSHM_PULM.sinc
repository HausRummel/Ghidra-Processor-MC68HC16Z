# --- PULM: Forward Display (CCR->D), Reverse P-Code (D->CCR) ---
pulmList: "" is regmask=0x00 {  }
pulmList: "CCR" is regmask=0x01 { pull16(CCR); unpackCCR(); }
pulmList: "K" is regmask=0x02 { local un:2; pull16(un); EK=un[12,4]; XK=un[8,4]; YK=un[4,4]; ZK=un[0,4]; }
