pshmList: "D,E,IX,IY,IZ" is regmask=31 { push16(IZ); push16(IY); push16(IX); push16(E); push16(D); }
pshmList: "K" is regmask=32 { local pk:2=(zext(EK:1)<<12)|(zext(XK:1)<<8)|(zext(YK:1)<<4)|zext(ZK:1); push16(pk); }
