pshmList: "D,E,IY,K" is regmask=0x2B { local pk:2=(zext(EK:1)<<12)|(zext(XK:1)<<8)|(zext(YK:1)<<4)|zext(ZK:1); push16(pk); push16(IY); push16(E); push16(D); }
pshmList: "IX,IY,K" is regmask=0x2C { local pk:2=(zext(EK:1)<<12)|(zext(XK:1)<<8)|(zext(YK:1)<<4)|zext(ZK:1); push16(pk); push16(IY); push16(IX); }
