pshmList: "E,IX,IZ,K" is regmask=0x36 { local pk:2=(zext(EK:1)<<12)|(zext(XK:1)<<8)|(zext(YK:1)<<4)|zext(ZK:1); push16(pk); push16(IZ); push16(IX); push16(E); }
pshmList: "D,E,IX,IZ,K" is regmask=0x37 { local pk:2=(zext(EK:1)<<12)|(zext(XK:1)<<8)|(zext(YK:1)<<4)|zext(ZK:1); push16(pk); push16(IZ); push16(IX); push16(E); push16(D); }
