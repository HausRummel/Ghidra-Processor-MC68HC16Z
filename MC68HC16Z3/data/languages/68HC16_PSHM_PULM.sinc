# 68HC16 PSHM/PULM Register Mapping

# --- PSHM: Forward Display (D->CCR), Reverse P-Code (CCR->D) ---
pshmList: "" is regmask=0x00 {  }
pshmList: "D" is regmask=0x01 { push16(D); }
pshmList: "E" is regmask=0x02 { push16(E); }
pshmList: "D,E" is regmask=0x03 { push16(E); push16(D); }
pshmList: "IX" is regmask=0x04 { push16(IX); }
pshmList: "D,IX" is regmask=0x05 { push16(IX); push16(D); }
pshmList: "E,IX" is regmask=0x06 { push16(IX); push16(E); }
pshmList: "D,E,IX" is regmask=0x07 { push16(IX); push16(E); push16(D); }
pshmList: "IY" is regmask=0x08 { push16(IY); }
pshmList: "D,IY" is regmask=0x09 { push16(IY); push16(D); }
pshmList: "E,IY" is regmask=0x0A { push16(IY); push16(E); }
pshmList: "D,E,IY" is regmask=0x0B { push16(IY); push16(E); push16(D); }
pshmList: "IX,IY" is regmask=0x0C { push16(IY); push16(IX); }
pshmList: "D,IX,IY" is regmask=0x0D { push16(IY); push16(IX); push16(D); }
pshmList: "E,IX,IY" is regmask=0x0E { push16(IY); push16(IX); push16(E); }
pshmList: "D,E,IX,IY" is regmask=0x0F { push16(IY); push16(IX); push16(E); push16(D); }
pshmList: "IZ" is regmask=0x10 { push16(IZ); }
pshmList: "D,IZ" is regmask=0x11 { push16(IZ); push16(D); }
pshmList: "E,IZ" is regmask=0x12 { push16(IZ); push16(E); }
pshmList: "D,E,IZ" is regmask=0x13 { push16(IZ); push16(E); push16(D); }
pshmList: "IX,IZ" is regmask=0x14 { push16(IZ); push16(IX); }
pshmList: "D,IX,IZ" is regmask=0x15 { push16(IZ); push16(IX); push16(D); }
pshmList: "E,IX,IZ" is regmask=0x16 { push16(IZ); push16(IX); push16(E); }
pshmList: "D,E,IX,IZ" is regmask=0x17 { push16(IZ); push16(IX); push16(E); push16(D); }
pshmList: "IY,IZ" is regmask=0x18 { push16(IZ); push16(IY); }
pshmList: "D,IY,IZ" is regmask=0x19 { push16(IZ); push16(IY); push16(D); }
pshmList: "E,IY,IZ" is regmask=0x1A { push16(IZ); push16(IY); push16(E); }
pshmList: "D,E,IY,IZ" is regmask=0x1B { push16(IZ); push16(IY); push16(E); push16(D); }
pshmList: "IX,IY,IZ" is regmask=0x1C { push16(IZ); push16(IY); push16(IX); }
pshmList: "D,IX,IY,IZ" is regmask=0x1D { push16(IZ); push16(IY); push16(IX); push16(D); }
pshmList: "E,IX,IY,IZ" is regmask=0x1E { push16(IZ); push16(IY); push16(IX); push16(E); }
pshmList: "D,E,IX,IY,IZ" is regmask=0x1F { push16(IZ); push16(IY); push16(IX); push16(E); push16(D); }
pshmList: "K" is regmask=0x20 { local pk:2=(zext(EK:1)<<12)|(zext(XK:1)<<8)|(zext(YK:1)<<4)|zext(ZK:1); push16(pk); }
pshmList: "D,K" is regmask=0x21 { local pk:2=(zext(EK:1)<<12)|(zext(XK:1)<<8)|(zext(YK:1)<<4)|zext(ZK:1); push16(pk); push16(D); }
pshmList: "E,K" is regmask=0x22 { local pk:2=(zext(EK:1)<<12)|(zext(XK:1)<<8)|(zext(YK:1)<<4)|zext(ZK:1); push16(pk); push16(E); }
pshmList: "D,E,K" is regmask=0x23 { local pk:2=(zext(EK:1)<<12)|(zext(XK:1)<<8)|(zext(YK:1)<<4)|zext(ZK:1); push16(pk); push16(E); push16(D); }
pshmList: "IX,K" is regmask=0x24 { local pk:2=(zext(EK:1)<<12)|(zext(XK:1)<<8)|(zext(YK:1)<<4)|zext(ZK:1); push16(pk); push16(IX); }
