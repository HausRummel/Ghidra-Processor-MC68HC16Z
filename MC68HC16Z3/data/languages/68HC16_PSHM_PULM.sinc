pshmList: "E,IX,IY,IZ,K" is regmask=0x3E { local pk:2=(zext(EK:1)<<12)|(zext(XK:1)<<8)|(zext(YK:1)<<4)|zext(ZK:1); push16(pk); push16(IZ); push16(IY); push16(IX); push16(E); }
pshmList: "D,E,IX,IY,IZ,K" is regmask=0x3F { local pk:2=(zext(EK:1)<<12)|(zext(XK:1)<<8)|(zext(YK:1)<<4)|zext(ZK:1); push16(pk); push16(IZ); push16(IY); push16(IX); push16(E); push16(D); }
pshmList: "CCR" is regmask=0x40 { packCCR(); push16(CCR); }
pshmList: "D,CCR" is regmask=0x41 { packCCR(); push16(CCR); push16(D); }
pshmList: "E,CCR" is regmask=0x42 { packCCR(); push16(CCR); push16(E); }
pshmList: "D,E,CCR" is regmask=0x43 { packCCR(); push16(CCR); push16(E); push16(D); }
pshmList: "IX,CCR" is regmask=0x44 { packCCR(); push16(CCR); push16(IX); }
pshmList: "D,IX,CCR" is regmask=0x45 { packCCR(); push16(CCR); push16(IX); push16(D); }
pshmList: "E,IX,CCR" is regmask=0x46 { packCCR(); push16(CCR); push16(IX); push16(E); }
pshmList: "D,E,IX,CCR" is regmask=0x47 { packCCR(); push16(CCR); push16(IX); push16(E); push16(D); }
pshmList: "IY,CCR" is regmask=0x48 { packCCR(); push16(CCR); push16(IY); }
pshmList: "D,IY,CCR" is regmask=0x49 { packCCR(); push16(CCR); push16(IY); push16(D); }
