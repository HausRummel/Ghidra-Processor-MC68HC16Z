# 68HC16 PSHM/PULM Register Mapping

# --- PSHM: Forward Display (D->CCR), Reverse P-Code (CCR->D) ---
pshmList: "" is regmask=0 {  }
pshmList: "D" is regmask=1 { push16(D); }
pshmList: "E" is regmask=2 { push16(E); }
pshmList: "D,E" is regmask=3 { push16(E); push16(D); }
pshmList: "IX" is regmask=4 { push16(IX); }
pshmList: "D,IX" is regmask=5 { push16(IX); push16(D); }
pshmList: "E,IX" is regmask=6 { push16(IX); push16(E); }
pshmList: "D,E,IX" is regmask=7 { push16(IX); push16(E); push16(D); }
pshmList: "IY" is regmask=8 { push16(IY); }
pshmList: "D,IY" is regmask=9 { push16(IY); push16(D); }
pshmList: "E,IY" is regmask=10 { push16(IY); push16(E); }
